---
import type { CollectionEntry } from "astro:content";
import { categoryMeta, getArticlePath } from "@/data/site";

interface Props {
  articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;

---

<div class="card-grid">
  {articles.map((article) => {
    const meta = categoryMeta[article.data.category] ?? { abbr: "?", label: article.data.category, gradientClass: "thumb-stocks" };
    const path = getArticlePath(article);
    return (
      <a class="article-card" href={path}>
        <div class={`card-thumb ${meta.gradientClass}`}>
          {article.data.heroImage ? (
            <img class="card-thumb-img" src={article.data.heroImage} alt={article.data.title} loading="lazy" width="600" height="338" />
          ) : (
            <span class="card-thumb-abbr">{meta.abbr}</span>
          )}
        </div>
        <div class="card-body">
          <div class="card-tag-row">
            <span class={`card-tag tag-${article.data.category}`}>{meta.label}</span>
            <span class="card-read-time">{article.data.readingTime}</span>
          </div>
          <h3 class="card-title">{article.data.title}</h3>
          <p class="card-excerpt">{article.data.description}</p>
          <div class="card-footer">
            <span class="card-date">
              {article.data.updatedDate.toLocaleDateString("vi-VN", { day: "numeric", month: "long", year: "numeric" })}
            </span>
          </div>
        </div>
      </a>
    );
  })}
</div>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .article-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
  }

  .article-card:hover {
    box-shadow: none;
    transform: translate(4px, 4px);
    text-decoration: none;
  }

  /* Gradient thumbnails replaced by flat accents with borders */
  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .card-thumb-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-thumb-abbr {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    opacity: 0.25;
    letter-spacing: 0.04em;
  }

  .thumb-stocks   { background: var(--color-mint); }
  .thumb-etf      { background: var(--color-mint); }
  .thumb-fund     { background: var(--color-mint); }
  .thumb-bond     { background: var(--color-mint); }
  .thumb-derivative { background: var(--color-mint); }
  .thumb-analyse  { background: var(--color-lilac); }
  .thumb-technical { background: var(--color-lilac); }
  .thumb-review   { background: var(--color-peach); }
  .thumb-investor { background: var(--color-peach); }

  .card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-tag-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .card-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    background: var(--surface-alt);
    color: var(--text);
    border: 1px solid var(--line);
  }

  .tag-co-phieu { background: var(--color-mint); color: var(--text); }
  .tag-etf      { background: var(--color-mint); color: var(--text); }
  .tag-quy-dau-tu { background: var(--color-mint); color: var(--text); }
  .tag-trai-phieu { background: var(--color-mint); color: var(--text); }
  .tag-phai-sinh { background: var(--color-mint); color: var(--text); }
  .tag-phan-tich  { background: var(--color-lilac); color: var(--text); }
  .tag-phan-tich-ky-thuat { background: var(--color-lilac); color: var(--text); }
  .tag-reviews    { background: var(--color-peach); color: var(--text); }
  .tag-nha-dau-tu { background: var(--color-peach); color: var(--text); }

  .card-read-time {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    margin: 0 0 8px;
    transition: color var(--transition-fast);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card:hover .card-title {
    color: var(--brand);
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 16px;
    flex: 1;
  }

  .card-footer {
    border-top: 1px solid var(--line);
    padding-top: 12px;
    font-size: 0.8rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
