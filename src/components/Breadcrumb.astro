---
import { url } from "@/data/site";

interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;

// Prefix absolute internal hrefs with the configured `base` (e.g. /investing on
// GitHub Pages). Idempotent: skips hrefs already prefixed, external, or anchors —
// so callers can pass either raw paths ("/", "/dau-tu/") or already-prefixed ones.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (href?: string) => {
  if (!href || !href.startsWith("/") || href.startsWith("//")) return href;
  if (base && (href === base || href.startsWith(`${base}/`))) return href;
  return url(href);
};
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {items.map((item, index) => (
      index === items.length - 1 ? (
        <li>
          <span aria-current="page">{item.label}</span>
        </li>
      ) : (
        <li>
          <a href={withBase(item.href)}>{item.label}</a>
          <span class="separator" aria-hidden="true">/</span>
        </li>
      )
    ))}
  </ol>
</nav>

<style>
  .breadcrumb {
    font-size: 0.85rem;
  }

  .breadcrumb ol {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .breadcrumb a {
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .breadcrumb .separator {
    color: var(--muted);
    font-weight: 500;
  }

  .breadcrumb [aria-current="page"] {
    color: var(--muted);
    font-weight: 500;
  }
</style>
