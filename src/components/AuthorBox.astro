---
import { author } from "@/data/authors";
---

<aside class="author-box">
  <div class="author-avatar" aria-hidden="true">
    {author.name.split(" ").pop()?.charAt(0)}
  </div>
  <div class="author-info">
    <div class="author-heading">
      <div>
        <p class="author-label">Về tác giả</p>
        <a class="author-name" href={`/author/${author.slug}`}>{author.name}</a>
      </div>
      <a class="author-profile-link" href={`/author/${author.slug}`}>Xem hồ sơ</a>
    </div>
    <p class="author-role">{author.role}</p>
    <p class="author-bio">{author.bio}</p>
    <div class="author-expertise" aria-label="Chuyên môn tác giả">
      {author.expertise.map((item) => <span>{item}</span>)}
    </div>
    {author.credentials.length > 0 && (
      <div class="author-credentials" aria-label="Chứng chỉ chuyên môn">
        <p class="author-sublabel">Chứng chỉ</p>
        <ul>
          {author.credentials.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    )}
    <p class="author-experience">{author.experience}</p>
    <p class="author-note">
      Nội dung được viết cho mục đích giáo dục tài chính, ưu tiên nguồn chính thống và tiếp nhận phản hồi đính chính qua email công khai.
    </p>
  </div>
</aside>

<style>
  .author-box {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-6);
    margin-top: var(--space-12);
    border: 1px solid var(--line);
    border-radius: 0px;
    background: var(--surface);
    border-left: 8px solid var(--brand);
    box-shadow: var(--shadow-md);
  }

  .author-avatar {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 0px;
    border: 1px solid var(--line);
    background: var(--brand);
    color: #fff;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0px var(--line);
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .author-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .author-label {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
  }

  .author-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .author-name:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .author-profile-link {
    flex-shrink: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface-alt);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 7px 10px;
    text-decoration: none;
    box-shadow: 1px 1px 0px var(--line);
  }

  .author-profile-link:hover {
    background: var(--color-mint);
    text-decoration: none;
  }

  .author-role {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .author-bio,
  .author-note,
  .author-experience {
    margin: var(--space-1) 0 0;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .author-sublabel {
    margin: 0 0 var(--space-1);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .author-credentials ul {
    margin: 0;
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: var(--space-1);
  }

  .author-expertise {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: var(--space-3);
  }

  .author-expertise span {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--color-mint);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 6px 9px;
  }

  @media (max-width: 560px) {
    .author-box {
      flex-direction: column;
    }

    .author-heading {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
