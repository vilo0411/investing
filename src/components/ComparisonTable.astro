---
interface Props {
  columns: string[];
  rows: (string | number)[][];
  caption?: string;
  /** rowIndex -> array of winning column indices, highlighted with a `winner-cell` style */
  highlightMap?: Record<number, number[]>;
}

const { columns, rows, caption, highlightMap = {} } = Astro.props;
---

<div class="comparison-table-wrap">
  <table class="comparison-table">
    {caption && <caption>{caption}</caption>}
    <thead>
      <tr>
        {columns.map((col) => <th>{col}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, rowIndex) => (
        <tr>
          {row.map((cell, colIndex) => (
            highlightMap[rowIndex]?.includes(colIndex) ? (
              <td class="winner-cell">
                <strong>{cell}</strong>
                <span class="winner-badge" aria-label="Tốt nhất">✓</span>
              </td>
            ) : (
              <td>{cell}</td>
            )
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .comparison-table-wrap {
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
  }

  .comparison-table th {
    background: var(--brand);
    color: #ffffff;
    text-align: left;
    padding: var(--space-3) var(--space-4);
    white-space: nowrap;
    border: 1px solid var(--line);
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
  }

  .comparison-table td {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--line);
    color: var(--text);
    font-weight: 500;
  }

  .comparison-table tbody tr:nth-child(even) {
    background: var(--surface-alt);
  }

  .comparison-table td.winner-cell {
    background: var(--color-mint);
    position: relative;
  }

  .winner-badge {
    display: inline-block;
    margin-left: 6px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #1a7a4a;
    vertical-align: middle;
  }
</style>
