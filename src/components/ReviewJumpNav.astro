---
interface Props {
  items: { label: string; href: string }[];
}

const { items } = Astro.props;
---

<nav class="review-jump-nav" id="review-jump-nav" aria-label="Điều hướng nhanh trong bài">
  <div class="jump-nav-wrap">
    <div class="jump-nav-inner">
      <span class="jump-nav-prefix" aria-hidden="true">Đọc nhanh</span>
      <ul>
        {items.map((item, i) => (
          <li>
            <a href={item.href} class="jump-link" data-href={item.href}>
              <span class="jump-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("review-jump-nav");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>(".jump-link");
    const sectionIds = Array.from(links).map((l) => l.getAttribute("data-href")?.replace("#", ""));
    const wrap = nav.querySelector<HTMLElement>(".jump-nav-wrap");

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove("jump-link--active"));
            const active = nav.querySelector<HTMLAnchorElement>(`[data-href="#${entry.target.id}"]`);
            if (active) {
              active.classList.add("jump-link--active");
              // Scroll heading bị khuất vào vùng nhìn thấy
              active.scrollIntoView({ behavior: "smooth", inline: "nearest", block: "nearest" });
            }
          }
        }
      },
      { rootMargin: "-120px 0px -60% 0px", threshold: 0 }
    );

    sectionIds.forEach((id) => {
      if (id) {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      }
    });

    // Cập nhật fade: ẩn khi scroll đến cuối
    if (wrap) {
      const updateFade = () => {
        const atEnd = wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 4;
        wrap.classList.toggle("is-end", atEnd);
      };
      wrap.addEventListener("scroll", updateFade, { passive: true });
      updateFade();

      // Chuyển vertical wheel → horizontal scroll khi hover trên nav
      wrap.addEventListener("wheel", (e) => {
        if (wrap.scrollWidth <= wrap.clientWidth) return; // không cần scroll nếu vừa khít
        e.preventDefault();
        wrap.scrollBy({ left: e.deltaY + e.deltaX, behavior: "auto" });
      }, { passive: false });
    }
  }
</script>

<style>
  .review-jump-nav {
    position: sticky;
    top: 68px;
    z-index: 90;
    background: var(--surface);
    border-bottom: 2px solid var(--line);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  /* Scroll container: căn giữa, giới hạn width, overflow ẩn */
  .jump-nav-wrap {
    width: min(100%, var(--article, 740px));
    margin-inline: auto;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    /* Fade bên phải báo hiệu còn nội dung */
    mask-image: linear-gradient(to right, black calc(100% - 48px), transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black calc(100% - 48px), transparent 100%);
  }

  .jump-nav-wrap::-webkit-scrollbar { display: none; }

  /* Tắt fade khi đã scroll đến cuối */
  .jump-nav-wrap.is-end {
    mask-image: none;
    -webkit-mask-image: none;
  }

  /* Flex row thực sự, tự giãn theo nội dung */
  .jump-nav-inner {
    display: flex;
    align-items: stretch;
    gap: 0;
    white-space: nowrap;
    min-width: max-content;
    padding: 0 16px;
  }

  .jump-nav-prefix {
    display: flex;
    align-items: center;
    padding: 0 var(--space-4) 0 0;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    border-right: 1px solid var(--line);
    margin-right: var(--space-3);
    flex-shrink: 0;
  }

  .review-jump-nav ul {
    display: flex;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .jump-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px var(--space-4);
    color: var(--muted);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    letter-spacing: 0.01em;
    border-bottom: 3px solid transparent;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
    position: relative;
  }

  .jump-link:hover {
    color: var(--text);
    background: var(--surface-alt);
  }

  .jump-link--active {
    color: var(--brand);
    border-bottom-color: var(--brand);
    background: var(--surface-alt);
  }

  .jump-num {
    font-size: 0.64rem;
    font-weight: 700;
    font-family: var(--font-sans);
    color: var(--line);
    letter-spacing: 0;
    transition: color 0.12s;
  }

  .jump-link:hover .jump-num,
  .jump-link--active .jump-num {
    color: var(--brand);
  }

  @media (max-width: 580px) {
    .jump-nav-inner {
      padding: 0 8px;
    }

    .jump-nav-prefix {
      display: none;
    }

    .jump-link {
      padding: 12px var(--space-3);
      font-size: 0.76rem;
    }

    .jump-num {
      display: none;
    }
  }
</style>
