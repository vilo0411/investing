---
interface Props {
  items: { label: string; href: string }[];
}

const { items } = Astro.props;
---

<nav class="review-jump-nav" id="review-jump-nav" aria-label="Điều hướng nhanh trong bài">
  <ul>
    {items.map((item) => (
      <li>
        <a href={item.href} class="jump-link" data-href={item.href}>{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<script>
  // Highlight active section as user scrolls
  const nav = document.getElementById("review-jump-nav");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>(".jump-link");
    const sectionIds = Array.from(links).map((l) => l.getAttribute("data-href")?.replace("#", ""));

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove("jump-link--active"));
            const active = nav.querySelector<HTMLAnchorElement>(`[data-href="#${entry.target.id}"]`);
            if (active) active.classList.add("jump-link--active");
          }
        }
      },
      { rootMargin: "-120px 0px -60% 0px", threshold: 0 }
    );

    sectionIds.forEach((id) => {
      if (id) {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      }
    });
  }
</script>

<style>
  .review-jump-nav {
    position: sticky;
    /* sits below site-header: 4px accent-bar + 64px nav = 68px */
    top: 68px;
    z-index: 90;
    background: var(--surface);
    border-bottom: 2px solid var(--line);
    box-shadow: 0 2px 0 var(--line), 3px 3px 0 var(--line);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .review-jump-nav::-webkit-scrollbar { display: none; }

  .review-jump-nav ul {
    display: flex;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    white-space: nowrap;
  }

  .jump-link {
    display: block;
    padding: 12px var(--space-5);
    color: var(--muted);
    font-weight: 700;
    font-size: 0.84rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 3px solid transparent;
    transition: color 0.12s ease, border-color 0.12s ease;
  }

  .jump-link:hover {
    color: var(--text);
  }

  .jump-link--active {
    color: var(--brand);
    border-bottom-color: var(--brand);
  }

  @media (max-width: 580px) {
    .jump-link {
      padding: 10px var(--space-4);
      font-size: 0.78rem;
    }
  }
</style>
