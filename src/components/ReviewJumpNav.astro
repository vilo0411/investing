---
interface Props {
  items: { label: string; href: string }[];
}

const { items } = Astro.props;
---

<nav class="review-jump-nav" aria-label="Điều hướng nhanh trong bài">
  <ul>
    {items.map((item) => (
      <li>
        <a href={item.href}>{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .review-jump-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    overflow-x: auto;
  }

  .review-jump-nav ul {
    display: flex;
    gap: var(--space-6);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    list-style: none;
    white-space: nowrap;
  }

  .review-jump-nav a {
    color: var(--text);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .review-jump-nav a:hover {
    color: var(--brand);
  }
</style>
