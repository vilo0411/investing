---
import ComparisonTable from "@/components/ComparisonTable.astro";
import ProsConsBox from "@/components/ProsConsBox.astro";
import ReviewCTA from "@/components/ReviewCTA.astro";

interface Broker {
  name: string;
  slug: string;
  rating: number;
  best_for: string;
  pros: string[];
  cons: string[];
  verdict?: string;
  fee_rate?: string;
  margin_rate?: string;
  app_rating?: string;
  min_deposit?: string;
  logo?: string;
  ctaUrl?: string;
}

interface Props {
  brokers: Broker[];
  comparisonCriteria: { label: string; key: string }[];
  winnerByCriteria: Record<string, string>;
  bestForScenarios: { scenario: string; winnerSlug: string; reason: string }[];
}

const { brokers, comparisonCriteria, winnerByCriteria, bestForScenarios } = Astro.props;

const columns = ["Tiêu chí", ...brokers.map((b) => b.name)];

const rows: (string | number)[][] = comparisonCriteria.map((criteria) => [
  criteria.label,
  ...brokers.map((broker) => {
    const value = (broker as unknown as Record<string, string | number | undefined>)[criteria.key];
    return value ?? "-";
  }),
]);

const highlightMap: Record<number, number[]> = {};
comparisonCriteria.forEach((criteria, rowIndex) => {
  const winnerSlug = winnerByCriteria[criteria.key];
  if (!winnerSlug) return;
  const brokerIndex = brokers.findIndex((b) => b.slug === winnerSlug);
  if (brokerIndex === -1) return;
  highlightMap[rowIndex] = [brokerIndex + 1];
});

// Calculate win counts for each broker
const winCounts = brokers.map((b) => ({
  broker: b,
  wins: Object.values(winnerByCriteria).filter((slug) => slug === b.slug).length,
}));
winCounts.sort((a, b) => b.wins - a.wins);
const totalCriteria = comparisonCriteria.length;
const overallWinner = winCounts[0];
---

<div class="comparison-body">

  <!-- Verdict strip: winner row + runner-up rows -->
  <div class="verdict-strip">
    <p class="verdict-strip-eyebrow">Kết luận tổng thể</p>

    {winCounts.map((wc, i) => (
      <div class:list={["verdict-row", { "verdict-row--winner": i === 0 }]}>
        <div class="verdict-row-left">
          {i === 0 && (
            <span class="verdict-winner-badge">Người chiến thắng · {wc.wins}/{totalCriteria} tiêu chí</span>
          )}
          <span class="verdict-broker-name">{wc.broker.name}</span>
          {wc.broker.best_for && (
            <span class="verdict-best-for">Tốt cho: {wc.broker.best_for}</span>
          )}
        </div>
        {wc.broker.ctaUrl && (
          <div class="verdict-row-right">
            <ReviewCTA
              label={i === 0 ? `Mở tài khoản ${wc.broker.name}` : "Mở tài khoản"}
              url={wc.broker.ctaUrl}
            />
          </div>
        )}
      </div>
    ))}
  </div>

  <section id="so-sanh">
    <h2>So sánh nhanh</h2>
    {rows.length > 0 && (
      <ComparisonTable columns={columns} rows={rows} highlightMap={highlightMap} />
    )}
  </section>

  <section id="uu-nhuoc-diem">
    <h2>Ưu & nhược điểm từng bên</h2>
    <div class="broker-grid">
      {brokers.map((broker) => (
        <div class="broker-card">
          <div class="broker-card-header">
            <span class="broker-card-name">{broker.name}</span>
            <span class="broker-card-rating">{broker.rating.toFixed(1)}/5</span>
          </div>
          {broker.best_for && (
            <p class="broker-card-best-for">Tốt cho: {broker.best_for}</p>
          )}
          <ProsConsBox pros={broker.pros} cons={broker.cons} />
          {broker.verdict && (
            <p class="broker-card-verdict">{broker.verdict}</p>
          )}
        </div>
      ))}
    </div>
  </section>

  {bestForScenarios.length > 0 && (
    <section id="nen-chon-ai">
      <h2>Nên chọn ai?</h2>
      <div class="scenario-list">
        {bestForScenarios.map((scenario) => {
          const winner = brokers.find((b) => b.slug === scenario.winnerSlug);
          return (
            <div class="scenario-item">
              <div class="scenario-header">
                <span class="scenario-if">Nếu bạn là...</span>
                <p class="scenario-text">{scenario.scenario}</p>
              </div>
              <div class="scenario-body">
                {winner && (
                  <div class="scenario-winner-tag">
                    Lựa chọn tốt nhất: <strong>{winner.name}</strong>
                  </div>
                )}
                <p class="scenario-reason">{scenario.reason}</p>
                {winner?.ctaUrl && (
                  <ReviewCTA label={`Mở tài khoản ${winner.name}`} url={winner.ctaUrl} />
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}
</div>

<style>
  :global(#so-sanh),
  :global(#uu-nhuoc-diem),
  :global(#nen-chon-ai) {
    scroll-margin-top: 132px;
  }

  /* ── Verdict Strip ─────────────────────────────── */
  .verdict-strip {
    border: 1px solid var(--line);
    box-shadow: 3px 3px 0px var(--line);
    margin: var(--space-6) 0;
    overflow: hidden;
  }

  .verdict-strip-eyebrow {
    margin: 0;
    padding: 8px var(--space-5);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--brand);
  }

  .verdict-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .verdict-row--winner {
    background: var(--color-mint);
  }

  .verdict-row-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .verdict-winner-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand);
  }

  .verdict-broker-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .verdict-best-for {
    font-size: 0.84rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .verdict-row-right {
    flex-shrink: 0;
    min-width: 180px;
  }

  @media (max-width: 580px) {
    .verdict-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .verdict-row-right {
      width: 100%;
      min-width: unset;
    }
  }

  /* ── Broker Cards ─────────────────────────────── */
  .broker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-5);
    margin: var(--space-4) 0;
  }

  .broker-card {
    border: 1px solid var(--line);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .broker-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .broker-card-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
  }

  .broker-card-rating {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--brand);
    border: 1px solid var(--brand);
    padding: 2px 8px;
  }

  .broker-card-best-for {
    margin: 0;
    font-size: 0.84rem;
    color: var(--muted);
    font-style: italic;
  }

  .broker-card-verdict {
    margin: var(--space-2) 0 0;
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
    border-top: 1px solid var(--line);
    padding-top: var(--space-3);
  }

  /* ── Scenario Cards ─────────────────────────────── */
  .scenario-list {
    display: grid;
    gap: var(--space-4);
    margin: var(--space-4) 0;
  }

  .scenario-item {
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    background: var(--surface);
    overflow: hidden;
  }

  .scenario-header {
    background: var(--surface-alt);
    border-bottom: 1px solid var(--line);
    padding: var(--space-3) var(--space-5);
  }

  .scenario-if {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .scenario-text {
    margin: 0;
    font-weight: 700;
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.4;
  }

  .scenario-body {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .scenario-winner-tag {
    font-size: 0.88rem;
    color: var(--brand);
    font-weight: 600;
  }

  .scenario-winner-tag strong {
    color: var(--brand);
  }

  .scenario-reason {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }
</style>
