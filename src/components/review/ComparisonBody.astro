---
import ComparisonTable from "@/components/ComparisonTable.astro";
import ProsConsBox from "@/components/ProsConsBox.astro";
import ReviewCTA from "@/components/ReviewCTA.astro";
import type { RatingDimension, UserVoice } from "@/data/brokers";

interface Broker {
  name: string;
  shortName?: string;
  slug: string;
  rating: number;
  best_for: string;
  pros: string[];
  cons: string[];
  verdict?: string;
  fee_rate?: string;
  margin_rate?: string;
  app_rating?: string;
  min_deposit?: string;
  logo?: string;
  ctaUrl?: string;
  ratingBreakdown?: RatingDimension;
  userVoices?: UserVoice[];
}

interface Props {
  brokers: Broker[];
  comparisonCriteria: { label: string; key: string }[];
  winnerByCriteria: Record<string, string>;
  bestForScenarios: { scenario: string; winnerSlug: string; reason: string }[];
}

const { brokers, comparisonCriteria, winnerByCriteria, bestForScenarios } = Astro.props;

const columns = ["Tiêu chí", ...brokers.map((b) => b.name)];

const rows: (string | number)[][] = comparisonCriteria.map((criteria) => [
  criteria.label,
  ...brokers.map((broker) => {
    const value = (broker as unknown as Record<string, string | number | undefined>)[criteria.key];
    return value ?? "-";
  }),
]);

const highlightMap: Record<number, number[]> = {};
comparisonCriteria.forEach((criteria, rowIndex) => {
  const winnerSlug = winnerByCriteria[criteria.key];
  if (!winnerSlug) return;
  const brokerIndex = brokers.findIndex((b) => b.slug === winnerSlug);
  if (brokerIndex === -1) return;
  highlightMap[rowIndex] = [brokerIndex + 1];
});

const winCounts = brokers.map((b) => ({
  broker: b,
  wins: Object.values(winnerByCriteria).filter((slug) => slug === b.slug).length,
}));
winCounts.sort((a, b) => b.wins - a.wins);
const totalCriteria = comparisonCriteria.length;
const overallWinner = winCounts[0];

// Dimension scorecard for verdict section
const dimensions: { key: keyof RatingDimension; label: string }[] = [
  { key: "fee",       label: "Phí giao dịch" },
  { key: "app",       label: "Ứng dụng & Công cụ" },
  { key: "support",   label: "Hỗ trợ khách hàng" },
  { key: "stability", label: "Độ ổn định hệ thống" },
  { key: "products",  label: "Sản phẩm đầu tư" },
];

const hasBreakdown = brokers.some((b) => b.ratingBreakdown);
---

<div class="comparison-body">

  <!-- Verdict card: kết luận tổng thể với visual rõ ràng -->
  <div class="verdict-card" id="ket-luan-tong-the">
    <div class="verdict-card-header">
      <span class="verdict-card-eyebrow">Kết luận tổng thể</span>
      <div class="verdict-card-subtitle">
        Đánh giá dựa trên {dimensions.length} tiêu chí: phí giao dịch, ứng dụng, hỗ trợ khách hàng, độ ổn định hệ thống và đa dạng sản phẩm.
      </div>
    </div>

    <!-- Winner spotlight -->
    {overallWinner && (
      <div class="winner-spotlight">
        <div class="winner-spotlight-left">
          <div class="winner-spotlight-label">
            <span class="winner-crown">★</span>
            Lựa chọn tốt hơn trong hầu hết trường hợp
          </div>
          <div class="winner-name">{overallWinner.broker.name}</div>
          {overallWinner.broker.best_for && (
            <div class="winner-best-for">Phù hợp nhất: {overallWinner.broker.best_for}</div>
          )}
          <div class="winner-score-summary">
            Thắng {overallWinner.wins}/{totalCriteria} tiêu chí so sánh
            · Điểm tổng: {overallWinner.broker.rating.toFixed(1)}/5
          </div>
        </div>
        {overallWinner.broker.ctaUrl && (
          <div class="winner-spotlight-cta">
            <ReviewCTA
              label={`Mở tài khoản ${overallWinner.broker.shortName ?? overallWinner.broker.name}`}
              url={overallWinner.broker.ctaUrl}
            />
          </div>
        )}
      </div>
    )}

    <!-- Dimension scorecard: ai thắng từng tiêu chí -->
    {hasBreakdown && (
      <div class="verdict-scorecard">
        <div class="scorecard-header-row">
          <span class="scorecard-col-label">Tiêu chí đánh giá</span>
          {brokers.map((b) => (
            <span class="scorecard-broker-col">{b.shortName ?? b.name}</span>
          ))}
        </div>

        {dimensions.map((dim) => {
          const scores = brokers.map((b) => b.ratingBreakdown?.[dim.key] ?? 0);
          const maxScore = Math.max(...scores);
          return (
            <div class="scorecard-row">
              <span class="scorecard-dim-label">{dim.label}</span>
              {brokers.map((b, idx) => {
                const score = b.ratingBreakdown?.[dim.key] ?? 0;
                const isWinner = score === maxScore && score > 0;
                const scoreClass = score >= 4.5 ? "excellent" : score >= 3.5 ? "good" : "fair";
                return (
                  <div class:list={["scorecard-cell", { "scorecard-cell--winner": isWinner }]}>
                    <span class:list={["scorecard-value", `scorecard-value--${scoreClass}`]}>
                      {score > 0 ? score.toFixed(1) : "—"}
                    </span>
                    {isWinner && <span class="scorecard-win-mark" aria-label="Tốt hơn">✓</span>}
                  </div>
                );
              })}
            </div>
          );
        })}

        <!-- Overall row -->
        <div class="scorecard-row scorecard-row--total">
          <span class="scorecard-dim-label">Điểm tổng</span>
          {brokers.map((b) => {
            const isWinner = b.slug === overallWinner?.broker.slug;
            return (
              <div class:list={["scorecard-cell", { "scorecard-cell--winner": isWinner }]}>
                <span class:list={["scorecard-value", "scorecard-value--total", { "scorecard-value--winner": isWinner }]}>
                  {b.rating.toFixed(1)}
                </span>
              </div>
            );
          })}
        </div>

        <p class="scorecard-methodology">
          Thang điểm 1–5 theo từng tiêu chí. Điểm tổng là điểm biên tập Value Investing, không phải trung bình đơn giản.
          Dữ liệu từ: trang web chính thức, App Store / Google Play, báo cáo thị phần HOSE.
        </p>
      </div>
    )}

    <!-- Runner-up row nếu có nhiều hơn 1 broker -->
    {winCounts.slice(1).map((wc) => (
      <div class="runner-up-row">
        <div class="runner-up-left">
          <span class="runner-up-label">Lựa chọn thay thế</span>
          <span class="runner-up-name">{wc.broker.name}</span>
          {wc.broker.best_for && (
            <span class="runner-up-best-for">Phù hợp: {wc.broker.best_for}</span>
          )}
        </div>
        {wc.broker.ctaUrl && (
          <ReviewCTA label="Mở tài khoản" url={wc.broker.ctaUrl} />
        )}
      </div>
    ))}
  </div>

  <section id="so-sanh">
    <h2>So sánh nhanh</h2>
    {rows.length > 0 && (
      <ComparisonTable columns={columns} rows={rows} highlightMap={highlightMap} />
    )}
  </section>

  <section id="uu-nhuoc-diem">
    <h2>Ưu & nhược điểm từng bên</h2>
    <div class="broker-grid">
      {brokers.map((broker) => (
        <div class="broker-card">
          <div class="broker-card-header">
            <span class="broker-card-name">{broker.name}</span>
            <span class="broker-card-rating">{broker.rating.toFixed(1)}/5</span>
          </div>
          {broker.best_for && (
            <p class="broker-card-best-for">Tốt cho: {broker.best_for}</p>
          )}
          <ProsConsBox pros={broker.pros} cons={broker.cons} />
          {broker.verdict && (
            <p class="broker-card-verdict">{broker.verdict}</p>
          )}

          <!-- Inline user voices per broker -->
          {broker.userVoices && broker.userVoices.length > 0 && (
            <div class="broker-voices">
              {broker.userVoices.slice(0, 2).map((v) => (
                <div class:list={["broker-voice", `broker-voice--${v.type}`]}>
                  <span class="broker-voice-badge">{v.type === "pro" ? "✓" : "✗"}</span>
                  <div class="broker-voice-content">
                    <p class="broker-voice-quote">"{v.quote}"</p>
                    <span class="broker-voice-source">{v.source}</span>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  {bestForScenarios.length > 0 && (
    <section id="nen-chon-ai">
      <h2>Nên chọn ai?</h2>
      <div class="scenario-list">
        {bestForScenarios.map((scenario) => {
          const winner = brokers.find((b) => b.slug === scenario.winnerSlug);
          return (
            <div class="scenario-item">
              <div class="scenario-header">
                <span class="scenario-if">Nếu bạn là...</span>
                <p class="scenario-text">{scenario.scenario}</p>
              </div>
              <div class="scenario-body">
                {winner && (
                  <div class="scenario-winner-tag">
                    Lựa chọn tốt nhất: <strong>{winner.name}</strong>
                  </div>
                )}
                <p class="scenario-reason">{scenario.reason}</p>
                {winner?.ctaUrl && (
                  <ReviewCTA label={`Mở tài khoản ${winner.name}`} url={winner.ctaUrl} />
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}
</div>

<style>
  :global(#so-sanh),
  :global(#uu-nhuoc-diem),
  :global(#nen-chon-ai),
  :global(#ket-luan-tong-the) {
    scroll-margin-top: 132px;
  }

  /* ── Verdict Card ─────────────────────────────── */
  .verdict-card {
    border: 2px solid var(--line);
    box-shadow: 4px 4px 0px var(--line);
    margin: var(--space-6) 0;
    overflow: hidden;
    background: var(--surface);
  }

  .verdict-card-header {
    background: var(--brand);
    padding: var(--space-3) var(--space-5);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .verdict-card-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }

  .verdict-card-subtitle {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.5;
  }

  /* ── Winner spotlight ─────────────────────────────── */
  .winner-spotlight {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: var(--color-mint);
    border-bottom: 1px solid var(--line);
  }

  .winner-spotlight-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .winner-spotlight-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .winner-crown { font-size: 0.85rem; }

  .winner-name {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  .winner-best-for {
    font-size: 0.84rem;
    color: var(--text);
    font-weight: 500;
  }

  .winner-score-summary {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 600;
  }

  .winner-spotlight-cta {
    flex-shrink: 0;
    min-width: 180px;
  }

  /* Remove top/bottom margin from CTA when inside spotlight */
  .winner-spotlight-cta :global(.review-cta-wrap) {
    margin: 0;
  }

  /* ── Dimension Scorecard ─────────────────────────────── */
  .verdict-scorecard {
    border-top: 2px solid var(--line);
  }

  .scorecard-header-row {
    display: grid;
    grid-template-columns: 1fr repeat(var(--broker-count, 2), 100px);
    background: var(--text);
    border-bottom: 2px solid var(--line);
  }

  .scorecard-col-label {
    padding: 10px var(--space-4);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255,255,255,0.6);
  }

  .scorecard-broker-col {
    padding: 10px var(--space-3);
    font-size: 0.84rem;
    font-weight: 700;
    color: #fff;
    text-align: center;
    border-left: 1px solid rgba(255,255,255,0.15);
  }

  .scorecard-row {
    display: grid;
    grid-template-columns: 1fr repeat(var(--broker-count, 2), 100px);
    border-bottom: 1px solid var(--line);
  }

  .scorecard-row:last-of-type {
    border-bottom: none;
  }

  .scorecard-row--total {
    border-top: 2px solid var(--line);
    background: var(--surface-alt);
  }

  .scorecard-dim-label {
    padding: 11px var(--space-4);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    display: flex;
    align-items: center;
  }

  .scorecard-row--total .scorecard-dim-label {
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
  }

  .scorecard-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 11px var(--space-3);
    border-left: 1px solid var(--line);
    text-align: center;
    position: relative;
  }

  .scorecard-cell--winner {
    background: rgba(26, 122, 74, 0.07);
  }

  .scorecard-value {
    font-size: 0.94rem;
    font-weight: 700;
    color: var(--muted);
  }

  .scorecard-value--excellent { color: #1a7a4a; }
  .scorecard-value--good      { color: var(--brand); }
  .scorecard-value--fair      { color: #b45309; }

  .scorecard-row--total .scorecard-value {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text);
  }

  .scorecard-row--total .scorecard-cell--winner .scorecard-value {
    color: #1a7a4a;
  }

  .scorecard-win-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: #1a7a4a;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 900;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .scorecard-methodology {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    font-size: 0.76rem;
    color: var(--muted);
    line-height: 1.55;
    background: var(--surface-alt);
    border-top: 1px solid var(--line);
  }

  /* ── Runner-up rows ─────────────────────────────── */
  .runner-up-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .runner-up-row :global(.review-cta-wrap) {
    margin: 0;
  }

  .runner-up-row :global(.review-cta) {
    padding: 10px 20px;
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .runner-up-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .runner-up-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
  }

  .runner-up-name {
    font-weight: 700;
    font-size: 0.96rem;
    color: var(--text);
  }

  .runner-up-best-for {
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* ── Broker Cards ─────────────────────────────── */
  .broker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-5);
    margin: var(--space-4) 0;
  }

  .broker-card {
    border: 1px solid var(--line);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .broker-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-2);
  }

  .broker-card-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
  }

  .broker-card-rating {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--brand);
    border: 1px solid var(--brand);
    padding: 2px 8px;
    flex-shrink: 0;
  }

  .broker-card-best-for {
    margin: 0;
    font-size: 0.84rem;
    color: var(--muted);
    font-style: italic;
  }

  .broker-card-verdict {
    margin: 0;
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
    border-top: 1px solid var(--line);
    padding-top: var(--space-3);
  }

  /* Inline user voices in broker cards */
  .broker-voices {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--line);
    padding-top: var(--space-3);
  }

  .broker-voice {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    font-size: 0.84rem;
  }

  .broker-voice-badge {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    margin-top: 2px;
  }

  .broker-voice--pro .broker-voice-badge {
    color: #1a7a4a;
    background: rgba(26,122,74,0.1);
  }

  .broker-voice--con .broker-voice-badge {
    color: #b45309;
    background: rgba(180,83,9,0.1);
  }

  .broker-voice-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .broker-voice-quote {
    margin: 0;
    color: var(--text);
    font-size: 0.82rem;
    line-height: 1.55;
    font-style: italic;
  }

  .broker-voice-source {
    font-size: 0.72rem;
    color: var(--muted);
    font-style: normal;
    font-weight: 600;
  }

  /* ── Scenario Cards ─────────────────────────────── */
  .scenario-list {
    display: grid;
    gap: var(--space-4);
    margin: var(--space-4) 0;
  }

  .scenario-item {
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    background: var(--surface);
    overflow: hidden;
  }

  .scenario-header {
    background: var(--surface-alt);
    border-bottom: 1px solid var(--line);
    padding: var(--space-3) var(--space-5);
  }

  .scenario-if {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .scenario-text {
    margin: 0;
    font-weight: 700;
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.4;
  }

  .scenario-body {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .scenario-winner-tag {
    font-size: 0.88rem;
    color: var(--brand);
    font-weight: 600;
  }

  .scenario-winner-tag strong { color: var(--brand); }

  .scenario-reason {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 640px) {
    .winner-spotlight {
      flex-direction: column;
      align-items: flex-start;
    }

    .winner-spotlight-cta {
      width: 100%;
    }

    .scorecard-header-row,
    .scorecard-row {
      grid-template-columns: 1fr repeat(var(--broker-count, 2), 72px);
    }

    .scorecard-dim-label,
    .scorecard-col-label {
      font-size: 0.78rem;
      padding: 10px var(--space-3);
    }

    .runner-up-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
