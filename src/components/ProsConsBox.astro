---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="pros-cons-box">
  <div class="pros-col">
    <div class="pc-label">Ưu điểm</div>
    <div class="pc-list">
      {pros.map((item) => (
        <div class="pc-item pc-item--pro">
          <span class="pc-icon" aria-hidden="true">✓</span>
          <span class="pc-text">{item}</span>
        </div>
      ))}
    </div>
  </div>
  <div class="cons-col">
    <div class="pc-label">Nhược điểm</div>
    <div class="pc-list">
      {cons.map((item) => (
        <div class="pc-item pc-item--con">
          <span class="pc-icon" aria-hidden="true">✕</span>
          <span class="pc-text">{item}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .pros-cons-box {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  .pros-col,
  .cons-col {
    border: 1px solid var(--line);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
  }

  .pros-col {
    background: var(--color-mint);
    border-left: 4px solid #1a7a4a;
  }

  .cons-col {
    background: var(--color-peach);
    border-left: 4px solid #b83232;
  }

  .pc-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: var(--space-3);
  }

  .pc-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pc-item {
    display: flex;
    align-items: baseline;
    gap: 7px;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--text);
  }

  .pc-icon {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 900;
    line-height: 1;
    position: relative;
    top: 1px;
  }

  .pc-item--pro .pc-icon { color: #1a7a4a; }
  .pc-item--con .pc-icon { color: #b83232; }

  .pc-text {
    flex: 1;
  }

  @media (max-width: 580px) {
    .pros-cons-box {
      grid-template-columns: 1fr;
    }
  }
</style>
