---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <aside class="key-takeaways" aria-label="Tóm tắt nội dung chính">
    <p class="kt-label">Tóm tắt nội dung chính</p>
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </aside>
)}

<style>
  .key-takeaways {
    padding: var(--space-6);
    border: 1px solid var(--line);
    border-radius: 0px;
    background: var(--color-mint);
    border-left: 6px solid var(--line);
    box-shadow: var(--shadow-md);
  }

  .kt-label {
    margin: 0 0 var(--space-2);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
  }

  .key-takeaways ul {
    margin: 0;
    padding-left: 1.25rem;
    list-style: none;
    display: grid;
    gap: var(--space-2);
  }

  .key-takeaways li {
    font-size: 0.96rem;
    color: var(--text);
    line-height: 1.6;
    position: relative;
    font-weight: 500;
  }

  .key-takeaways li::before {
    content: "";
    position: absolute;
    left: -1.25rem;
    top: 0.6rem;
    width: 5px;
    height: 5px;
    background-color: var(--text);
    border-radius: 0px;
  }
</style>
