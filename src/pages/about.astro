---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories, getArticlePath, site } from "@/data/site";
import { author } from "@/data/authors";

const articles = await getCollection("articles");
const latestArticles = articles
  .toSorted((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime())
  .slice(0, 6);

const articleCount = articles.length;
const categoryCount = new Set(articles.map((article) => article.data.category)).size;
const authorInitial = author.name.split(" ").pop()?.charAt(0) ?? author.name.charAt(0);
const categoryLabels = new Map(categories.map((category) => [category.slug, category.title]));
---

<BaseLayout title="Tác giả" description="Thông tin tác giả, chuyên môn và định hướng biên tập của ValueInvesting.com.vn.">
  <section class="author-hero">
    <div class="container author-hero-grid">
      <div class="author-identity">
        <div class="author-avatar-large" aria-hidden="true">{authorInitial}</div>
        <div>
          <div class="profile-links">
            <a href={`mailto:${site.email}`}>Email</a>
            <a href="/editorial-policy/">Chính sách biên tập</a>
          </div>
          <h1>{author.name}</h1>
          <p class="author-role">{author.role}</p>
        </div>
      </div>

      <aside class="expertise-panel" aria-label="Chuyên môn tác giả">
        <p class="panel-label">Chuyên môn</p>
        <ul>
          {author.expertise.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="author-body">
    <div class="container author-layout">
      <main class="author-main">
        <section class="quote-block" aria-label="Quan điểm về tiền và đầu tư">
          <p class="panel-label">Quan điểm về đầu tư</p>
          <blockquote>“{author.moneyPerspective}”</blockquote>
        </section>

        <section class="bio-section">
          <h2>Giới thiệu</h2>
          <p>
            {author.name} phụ trách nội dung tại {site.name}, tập trung xây dựng kiến thức đầu tư dài hạn,
            phân tích cơ bản và đánh giá sản phẩm tài chính theo hướng minh bạch, có nguồn và phù hợp với
            người mới bắt đầu.
          </p>
          <p>
            Nội dung trên website được viết cho mục đích giáo dục, không thay thế tư vấn tài chính cá nhân
            và không đưa ra khuyến nghị mua bán cổ phiếu, chứng chỉ quỹ hoặc sản phẩm đầu tư cụ thể.
          </p>
        </section>

        <section class="latest-section">
          <div class="section-heading-row">
            <div>
              <p class="panel-label">Bài viết mới</p>
              <h2>Mới nhất từ {author.name.split(" ").pop()}</h2>
            </div>
            <a href="/dau-tu/">Xem chủ đề đầu tư</a>
          </div>
          <div class="latest-author-list">
            {latestArticles.map((article) => (
              <a class="latest-author-item" href={getArticlePath(article)}>
                <span>{categoryLabels.get(article.data.category) ?? article.data.category}</span>
                <strong>{article.data.title}</strong>
                <small>
                  Cập nhật {article.data.updatedDate.toLocaleDateString("vi-VN")} · {article.data.readingTime}
                </small>
              </a>
            ))}
          </div>
        </section>
      </main>

      <aside class="author-sidebar" aria-label="Thông tin hồ sơ">
        <div class="stat-stack">
          <div>
            <strong>{articleCount}</strong>
            <span>Bài viết đã xuất bản</span>
          </div>
          <div>
            <strong>{categoryCount}</strong>
            <span>Nhóm chủ đề đầu tư</span>
          </div>
          <div>
            <strong>2026</strong>
            <span>Năm cập nhật hồ sơ</span>
          </div>
        </div>

        <div class="profile-card">
          <h2>Kinh nghiệm nội dung</h2>
          <p>{author.experience}</p>
        </div>

        <div class="profile-card">
          <h2>Học vấn và chứng chỉ</h2>
          <p>{author.education}</p>
        </div>

        <div class="profile-card">
          <h2>Đã xuất bản tại</h2>
          <div class="published-list">
            {author.publishedIn.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .author-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    padding: 52px 0 34px;
  }

  .author-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: end;
  }

  .author-identity {
    display: grid;
    grid-template-columns: 148px minmax(0, 1fr);
    gap: 28px;
    align-items: center;
  }

  .author-avatar-large {
    width: 148px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 26%, var(--color-neutral-50) 0 0, var(--color-neutral-50) 18%, var(--color-brand-700) 19%, var(--color-brand-900) 72%);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 4.4rem;
    line-height: 1;
    box-shadow: 0 10px 28px rgba(10, 37, 64, 0.18);
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 14px;
  }

  .profile-links a,
  .section-heading-row a {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .profile-links a:hover,
  .section-heading-row a:hover {
    text-decoration: underline;
  }

  .author-identity h1 {
    margin: 0 0 8px;
    color: var(--text);
    font-size: clamp(2.4rem, 5vw, 4.3rem);
  }

  .author-role {
    margin: 0;
    color: var(--muted);
    font-size: 1.05rem;
    font-weight: 700;
  }

  .expertise-panel,
  .quote-block,
  .profile-card,
  .stat-stack {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .expertise-panel {
    padding: 22px;
  }

  .panel-label {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .expertise-panel ul,
  .profile-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    line-height: 1.7;
  }

  .author-body {
    padding: 42px 0 64px;
  }

  .author-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: start;
  }

  .author-main {
    display: grid;
    gap: 34px;
  }

  .quote-block {
    padding: 26px 28px;
    border-left: 4px solid var(--color-brand-900);
  }

  .quote-block blockquote {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.05rem);
    line-height: 1.25;
  }

  .bio-section h2,
  .latest-section h2,
  .profile-card h2 {
    margin: 0 0 12px;
    color: var(--text);
  }

  .bio-section p,
  .profile-card p {
    color: #1a2330;
    line-height: 1.8;
    margin: 0 0 14px;
  }

  .section-heading-row {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    margin-bottom: 18px;
  }

  .latest-author-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .latest-author-item {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 12px 18px;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    color: inherit;
    text-decoration: none;
  }

  .latest-author-item span {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .latest-author-item strong {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .latest-author-item small {
    grid-column: 2;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .latest-author-item:hover {
    text-decoration: none;
  }

  .latest-author-item:hover strong {
    color: var(--brand);
  }

  .author-sidebar {
    display: grid;
    gap: 18px;
    position: sticky;
    top: 96px;
  }

  .stat-stack {
    display: grid;
    padding: 0 22px;
  }

  .stat-stack div {
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .stat-stack div:last-child {
    border-bottom: 0;
  }

  .stat-stack strong {
    display: block;
    color: var(--brand);
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1;
  }

  .stat-stack span {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .profile-card {
    padding: 22px;
  }

  .profile-card h2 {
    font-size: 1.15rem;
  }

  .profile-card p,
  .profile-card li {
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .published-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .published-list span {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--brand);
    font-size: 0.84rem;
    font-weight: 700;
    padding: 6px 10px;
  }

  @media (max-width: 900px) {
    .author-hero-grid,
    .author-layout {
      grid-template-columns: 1fr;
    }

    .author-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .author-hero {
      padding-top: 34px;
    }

    .author-identity {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .author-avatar-large {
      width: 112px;
      font-size: 3.2rem;
    }

    .latest-author-item {
      grid-template-columns: 1fr;
    }

    .latest-author-item small {
      grid-column: auto;
    }

    .section-heading-row {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
