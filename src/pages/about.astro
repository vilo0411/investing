---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { author } from "@/data/authors";

const articles = await getCollection("articles");
const articleCount = articles.length;
const categoryCount = new Set(articles.map((article) => article.data.category)).size;
const authorInitial = author.name.split(" ").pop()?.charAt(0) ?? author.name.charAt(0);

const editorialSteps = [
  {
    title: "Nghiên cứu & viết theo nguồn",
    description: "Mỗi bài viết bắt đầu từ câu hỏi thực tế của người mới đầu tư, tham khảo nguồn tài chính uy tín và trích dẫn rõ ràng.",
  },
  {
    title: "Rà soát nội dung & rủi ro",
    description: "Nội dung được kiểm tra lại để đảm bảo giải thích đúng khái niệm, nêu rõ rủi ro và không đưa ra khuyến nghị mua bán.",
  },
  {
    title: "Cập nhật định kỳ",
    description: "Bài viết được rà soát và cập nhật khi số liệu, quy định hoặc sản phẩm tài chính liên quan thay đổi.",
  },
];
---

<BaseLayout title="Giới thiệu" description="ValueInvesting.com.vn là nguồn kiến thức đầu tư bằng tiếng Việt cho người mới bắt đầu, có nguồn tham khảo và quy trình biên tập rõ ràng.">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Giới thiệu</div>
      <h1>Vì sao ValueInvesting.com.vn ra đời</h1>
      <p class="lead">
        Trang được xây dựng cho người mới bắt đầu đầu tư tại Việt Nam, cung cấp nội dung giáo dục có nguồn
        tham khảo rõ ràng. Chúng tôi không khuyến nghị mua hay bán bất kỳ cổ phiếu, chứng chỉ quỹ hoặc sản
        phẩm đầu tư cụ thể nào, và không cung cấp tín hiệu giao dịch.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Quy trình biên tập</div>
          <h2 class="section-title">Quy trình biên tập tóm tắt</h2>
        </div>
      </div>
      <div class="start-list">
        {editorialSteps.map((step, index) => (
          <div class="start-item">
            <span class="start-number">{String(index + 1).padStart(2, "0")}</span>
            <span>
              <strong>{step.title}</strong>
              <small>{step.description}</small>
            </span>
          </div>
        ))}
      </div>
      <p class="process-link">
        <a href="/editorial-policy/">Xem chính sách biên tập đầy đủ</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Tác giả</div>
          <h2 class="section-title">Người phụ trách nội dung</h2>
        </div>
      </div>
      <div class="author-preview-card">
        <div class="author-avatar-small" aria-hidden="true">{authorInitial}</div>
        <div>
          <strong>{author.name}</strong>
          <span class="author-role-small">{author.role}</span>
          <p class="author-bio-excerpt">{author.bio}</p>
          <a class="preview-cta" href={`/author/${author.slug}/`}>Xem hồ sơ đầy đủ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Thống kê</div>
          <h2 class="section-title">Quy mô nội dung</h2>
        </div>
      </div>
      <div class="stat-stack">
        <div>
          <strong>{articleCount}</strong>
          <span>Bài viết đã xuất bản</span>
        </div>
        <div>
          <strong>{categoryCount}</strong>
          <span>Nhóm chủ đề đầu tư</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .start-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .start-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 20px;
  }

  .start-number {
    color: var(--color-accent);
    font-weight: 800;
  }

  .start-item strong {
    color: var(--text);
    display: block;
    line-height: 1.35;
  }

  .start-item small {
    color: var(--muted);
    display: block;
    margin-top: 6px;
    line-height: 1.6;
  }

  .process-link {
    margin: 20px 0 0;
  }

  .process-link a {
    color: var(--brand);
    font-weight: 700;
    text-decoration: none;
  }

  .process-link a:hover {
    text-decoration: underline;
  }

  .author-preview-card {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 20px;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: var(--space-6, 24px);
  }

  .author-avatar-small {
    width: 64px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 26%, var(--color-neutral-50) 0 0, var(--color-neutral-50) 18%, var(--color-brand-700) 19%, var(--color-brand-900) 72%);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    line-height: 1;
  }

  .author-preview-card strong {
    display: block;
    color: var(--text);
    font-size: 1.1rem;
    margin-bottom: 2px;
  }

  .author-role-small {
    display: block;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .author-bio-excerpt {
    margin: 0 0 12px;
    color: var(--muted);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .preview-cta {
    color: var(--brand);
    font-weight: 700;
    text-decoration: none;
  }

  .preview-cta:hover {
    text-decoration: underline;
  }

  .stat-stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 0 22px;
  }

  .stat-stack div {
    padding: 20px 0;
  }

  .stat-stack div:not(:last-child) {
    border-right: 1px solid var(--line);
  }

  .stat-stack strong {
    display: block;
    color: var(--brand);
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1;
  }

  .stat-stack span {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .start-list {
      grid-template-columns: 1fr;
    }

    .author-preview-card {
      grid-template-columns: 1fr;
    }

    .stat-stack {
      grid-template-columns: 1fr;
    }

    .stat-stack div:not(:last-child) {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
