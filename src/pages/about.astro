---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { author } from "@/data/authors";
import { url } from "@/data/site";

const articles = await getCollection("articles");
const articleCount = articles.length;
const categoryCount = new Set(articles.map((article) => article.data.category)).size;
const authorInitial = author.name.split(" ").pop()?.charAt(0) ?? author.name.charAt(0);

const editorialSteps = [
  {
    title: "Nghiên cứu & viết theo nguồn",
    description: "Mỗi bài viết bắt đầu từ câu hỏi thực tế của người mới đầu tư, tham khảo nguồn tài chính uy tín và trích dẫn rõ ràng.",
  },
  {
    title: "Rà soát nội dung & rủi ro",
    description: "Nội dung được kiểm tra lại để đảm bảo giải thích đúng khái niệm, nêu rõ rủi ro và không đưa ra khuyến nghị mua bán.",
  },
  {
    title: "Cập nhật định kỳ",
    description: "Bài viết được rà soát và cập nhật khi số liệu, quy định hoặc sản phẩm tài chính liên quan thay đổi.",
  },
];
---

<BaseLayout title="Về Value Investing | Sứ mệnh & Đội ngũ Biên tập" description="Value Investing là nền tảng giáo dục đầu tư tài chính uy tín tại Việt Nam. Tìm hiểu sứ mệnh, đội ngũ biên tập và quy trình kiểm duyệt nội dung YMYL.">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Giới thiệu</div>
      <h1>Vì sao Value Investing ra đời</h1>
      <p class="lead">
        Trang được xây dựng cho người mới bắt đầu đầu tư tại Việt Nam, cung cấp nội dung giáo dục có nguồn
        tham khảo rõ ràng. Blog không khuyến nghị mua hay bán bất kỳ cổ phiếu, chứng chỉ quỹ hoặc sản
        phẩm đầu tư cụ thể nào, và không cung cấp tín hiệu giao dịch.
      </p>
    </div>
  </section>

  <section class="section values-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Giá trị cốt lõi</div>
          <h2 class="section-title">Sứ mệnh & Định vị</h2>
        </div>
      </div>
      <div class="positioning-box">
        <strong>Định vị của blog</strong>
        <p>
          Value Investing là thư viện tra cứu kiến thức tài chính hệ thống, trung lập, được viết riêng cho bối cảnh thị trường Việt Nam (HOSE, HNX, UPCoM, UBCKNN, ETF VN30...).
        </p>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-badge">Gần gũi</div>
          <p>Viết như đang giải thích cho người bạn thân. Không dùng jargon nếu có thể dùng ngôn ngữ đời thường, lấy ví dụ từ cuộc sống Việt Nam (quán cà phê, xe máy, gửi tiết kiệm...).</p>
        </div>
        <div class="value-card">
          <div class="value-badge">Thành thật</div>
          <p>Nói thẳng về rủi ro, không hứa hẹn làm giàu nhanh hay phím mã đầu cơ. Xây dựng lòng tin bền vững thông qua sự trung thực.</p>
        </div>
        <div class="value-card">
          <div class="value-badge">Thực chiến</div>
          <p>Mỗi bài viết đều hướng đến hành động cụ thể để bạn có thể tự mình thực hành ngay (như tính các chỉ số định giá P/E, P/B, tự mở báo cáo tài chính).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Quy trình biên tập</div>
          <h2 class="section-title">Quy trình biên tập tóm tắt</h2>
        </div>
      </div>
      <div class="start-list">
        {editorialSteps.map((step, index) => (
          <div class="start-item">
            <span class="start-number">{String(index + 1).padStart(2, "0")}</span>
            <span>
              <strong>{step.title}</strong>
              <small>{step.description}</small>
            </span>
          </div>
        ))}
      </div>
      <p class="process-link">
        <a href={url("/editorial-policy/")}>Xem chính sách biên tập đầy đủ</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Tác giả</div>
          <h2 class="section-title">Người phụ trách nội dung</h2>
        </div>
      </div>
      <div class="author-preview-card">
        <div class="author-avatar-small" aria-hidden="true">
          {author.avatar
            ? <img src={url(author.avatar)} alt={author.name} width="64" height="64" />
            : authorInitial
          }
        </div>
        <div>
          <strong>{author.name}</strong>
          <span class="author-role-small">{author.role}</span>
          <p class="author-bio-excerpt">{author.bio}</p>
          <a class="preview-cta" href={url(`/author/${author.slug}/`)}>Xem hồ sơ đầy đủ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Thống kê</div>
          <h2 class="section-title">Quy mô nội dung</h2>
        </div>
      </div>
      <div class="stat-stack">
        <div>
          <strong>{articleCount}</strong>
          <span>Bài viết đã xuất bản</span>
        </div>
        <div>
          <strong>{categoryCount}</strong>
          <span>Nhóm chủ đề đầu tư</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .start-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .start-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .start-item:hover {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .start-number {
    color: var(--brand);
    font-weight: 800;
  }

  .start-item strong {
    color: var(--text);
    display: block;
    line-height: 1.35;
    font-weight: 700;
  }

  .start-item small {
    color: var(--muted);
    display: block;
    margin-top: 6px;
    line-height: 1.6;
    font-weight: 500;
  }

  .process-link {
    margin: 20px 0 0;
  }

  .process-link a {
    color: var(--brand);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .process-link a:hover {
    color: var(--brand-strong);
  }

  .author-preview-card {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 20px;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: var(--space-6, 24px);
    box-shadow: var(--shadow-sm);
  }

  .author-avatar-small {
    width: 64px;
    aspect-ratio: 1;
    border-radius: 0px;
    border: 1px solid var(--line);
    background: var(--brand);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    line-height: 1;
    box-shadow: 2px 2px 0px var(--line);
    overflow: hidden;
  }

  .author-avatar-small img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .author-preview-card strong {
    display: block;
    color: var(--text);
    font-size: 1.1rem;
    margin-bottom: 2px;
    font-weight: 700;
  }

  .author-role-small {
    display: block;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .author-bio-excerpt {
    margin: 0 0 12px;
    color: var(--muted);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .preview-cta {
    color: var(--brand);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .preview-cta:hover {
    color: var(--brand-strong);
  }

  .stat-stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 0 22px;
    box-shadow: var(--shadow-sm);
  }

  .stat-stack div {
    padding: 20px 0;
  }

  .stat-stack div:not(:last-child) {
    border-right: 1px solid var(--line);
  }

  .stat-stack strong {
    display: block;
    color: var(--brand);
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1;
    font-weight: 700;
  }

  .stat-stack span {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.5;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .start-list {
      grid-template-columns: 1fr;
    }

    .author-preview-card {
      grid-template-columns: 1fr;
    }

    .stat-stack {
      grid-template-columns: 1fr;
    }

    .stat-stack div:not(:last-child) {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }

  /* ── Values & Positioning Section ───────────────────────────────────── */
  .positioning-box {
    border: 1px solid var(--line);
    border-radius: 0px;
    background: var(--surface-alt);
    padding: 24px;
    margin-bottom: 32px;
    border-left: 8px solid var(--brand);
    box-shadow: var(--shadow-sm);
  }

  .positioning-box strong {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 8px;
  }

  .positioning-box p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 500;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .value-card {
    border: 1px solid var(--line);
    border-radius: 0px;
    background: var(--surface);
    padding: 24px;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .value-card:hover {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .value-badge {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    background: var(--color-mint);
    color: var(--text);
    border: 1px solid var(--line);
    box-shadow: 2px 2px 0px var(--line);
    margin-bottom: 16px;
  }

  .value-card p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
