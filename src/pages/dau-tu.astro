---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories, getCategoryPath } from "@/data/site";

const articles = await getCollection("articles");

const investing = categories
  .filter((cat) => cat.group === "Đầu tư")
  .map((cat) => ({
    ...cat,
    count: articles.filter((a) => a.data.category === cat.slug).length,
  }));

const gradients: Record<string, string> = {
  "co-phieu":   "thumb-stocks",
  "etf":        "thumb-etf",
  "quy-dau-tu": "thumb-fund",
  "trai-phieu": "thumb-bond",
  "phai-sinh":  "thumb-derivative",
};
---

<BaseLayout
  title="Đầu tư"
  description="Kiến thức nền tảng về cổ phiếu, ETF, quỹ đầu tư và trái phiếu cho người mới."
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Trang chủ</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Đầu tư</span>
      </nav>
      <div class="eyebrow">Hub nội dung</div>
      <h1>Đầu tư</h1>
      <p class="lead">
        Bắt đầu với các loại tài sản phổ biến, cách chúng hoạt động và những rủi ro cần hiểu trước khi xuống tiền.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cat-grid">
        {investing.map((cat) => (
          <a class="cat-card" href={getCategoryPath(cat)}>
            <div class={`cat-thumb ${gradients[cat.slug] ?? "thumb-stocks"}`}>
              <span class="cat-thumb-label">{cat.title}</span>
            </div>
            <div class="cat-body">
              <div class="cat-tag-row">
                <span class="cat-badge">Đầu tư</span>
                {cat.count > 0 && (
                  <span class="cat-count">{cat.count} bài viết</span>
                )}
              </div>
              <h2 class="cat-title">{cat.title}</h2>
              <p class="cat-desc">{cat.description}</p>
              <span class="cat-cta">Xem bài viết <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--muted);
    transition: color var(--transition);
  }

  .breadcrumb a:hover {
    color: var(--brand);
    text-decoration: none;
  }

  .breadcrumb span[aria-current] {
    color: var(--color-neutral-400);
  }

  /* ── Category card grid ─────────────────────────────────────────────── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }

  .cat-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 107, 44, 0.06);
    transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
  }

  .cat-card:hover {
    box-shadow: 0 6px 24px rgba(0, 107, 44, 0.12);
    transform: translateY(-3px);
    border-color: var(--color-brand-100);
    text-decoration: none;
  }

  .cat-thumb {
    width: 100%;
    aspect-ratio: 16 / 6;
    display: flex;
    align-items: flex-end;
    padding: 16px 20px;
  }

  .cat-thumb-label {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.2);
    letter-spacing: 0.02em;
  }

  .cat-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .cat-tag-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .cat-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-brand-900);
  }

  .cat-count {
    font-size: 0.82rem;
    color: var(--muted);
  }

  .cat-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 8px;
    line-height: 1.3;
    transition: color var(--transition);
  }

  .cat-card:hover .cat-title {
    color: var(--brand);
  }

  .cat-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cat-cta {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-brand-900);
    border-top: 1px solid var(--line);
    padding-top: 12px;
  }

  /* Gradient thumbnails */
  .thumb-stocks   { background: linear-gradient(135deg, #e8f8ee, #a7f3c0); }
  .thumb-etf      { background: linear-gradient(135deg, #eef2ff, #c7d2fe); }
  .thumb-fund     { background: linear-gradient(135deg, #fdf4ff, #e9d5ff); }
  .thumb-bond     { background: linear-gradient(135deg, #eff6ff, #bfdbfe); }
  .thumb-derivative { background: linear-gradient(135deg, #ecfeff, #a5f3fc); }

  @media (max-width: 640px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
