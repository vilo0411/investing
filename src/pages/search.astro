---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories, categoryMeta, getArticlePath } from "@/data/site";

const articles = (await getCollection("articles"))
  .toSorted((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime());

const searchIndex = articles.map((article) => {
  const meta = categoryMeta[article.data.category] ?? {
    label: article.data.category,
    abbr: "?",
    gradientClass: "thumb-stocks",
  };

  return {
    title: article.data.title,
    description: article.data.description,
    category: article.data.category,
    categoryLabel: meta.label,
    readingTime: article.data.readingTime,
    updatedDate: article.data.updatedDate.toLocaleDateString("vi-VN", {
      day: "numeric",
      month: "long",
      year: "numeric",
    }),
    href: getArticlePath(article),
    tags: article.data.tags,
    text: [
      article.data.title,
      article.data.description,
      meta.label,
      ...article.data.tags,
    ].join(" ").toLowerCase(),
  };
});
---

<BaseLayout title="Tìm kiếm" description="Tìm bài viết theo chủ đề, thuật ngữ hoặc nhóm nội dung trên Value Investing.">
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Trang chủ</a>
        <span class="separator" aria-hidden="true">/</span>
        <span aria-current="page">Tìm kiếm</span>
      </nav>
      <div class="eyebrow">Thư viện kiến thức</div>
      <h1>Tìm kiếm</h1>
      <p class="lead">Tra nhanh khái niệm, chỉ số tài chính, sản phẩm đầu tư và bài viết nền tảng cho người mới.</p>
    </div>
  </section>

  <section class="section">
    <div class="container search-shell">
      <form class="search-controls" role="search" aria-label="Tìm kiếm bài viết" data-search-form>
        <label class="search-label" for="search-query">Từ khóa</label>
        <input
          id="search-query"
          class="search-input"
          type="search"
          name="q"
          placeholder="Ví dụ: ETF, P/E, trái phiếu, công ty chứng khoán"
          autocomplete="off"
          data-search-input
        />
        <div class="filter-row" aria-label="Lọc theo chủ đề">
          <button class="filter-chip is-active" type="button" data-category="all">Tất cả</button>
          {categories.map((category) => (
            <button class="filter-chip" type="button" data-category={category.slug}>{category.title}</button>
          ))}
        </div>
      </form>

      <div class="search-summary" data-search-summary>{articles.length} bài viết</div>
      <div class="search-results" data-search-results></div>
    </div>
  </section>

  <script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />

  <style>
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: var(--space-4);
      flex-wrap: wrap;
    }

    .breadcrumb a {
      color: var(--text);
      font-weight: 700;
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    .breadcrumb a:hover {
      color: var(--brand);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .breadcrumb .separator {
      color: var(--muted);
      font-weight: 500;
    }

    .breadcrumb span[aria-current] {
      color: var(--muted);
      font-weight: 500;
    }

    .search-shell {
      display: grid;
      gap: 22px;
    }

    .search-controls {
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--surface);
      padding: 20px;
      box-shadow: var(--shadow-sm);
    }

    .search-label {
      display: block;
      color: var(--brand);
      font-weight: 800;
      font-size: 0.84rem;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .search-input {
      width: 100%;
      min-height: 48px;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: 0 14px;
      color: var(--text);
      font: inherit;
      font-weight: 500;
      outline: none;
      background: var(--surface);
      transition: box-shadow var(--transition-fast);
    }

    .search-input:focus {
      border-color: var(--line);
      box-shadow: 2px 2px 0px var(--line);
    }

    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .filter-chip {
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      background: var(--surface-alt);
      color: var(--text);
      cursor: pointer;
      font: inherit;
      font-size: 0.84rem;
      font-weight: 700;
      padding: 7px 11px;
      box-shadow: 1px 1px 0px var(--line);
      transition: background var(--transition-fast), transform var(--transition-fast);
    }

    .filter-chip.is-active,
    .filter-chip:hover {
      border-color: var(--line);
      background: var(--color-mint);
      color: var(--text);
    }

    .search-summary {
      color: var(--text);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .search-results {
      display: grid;
      gap: 12px;
    }

    .result-card {
      display: grid;
      gap: 8px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--surface);
      padding: 18px 20px;
      text-decoration: none;
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .result-card:hover {
      transform: translate(2px, 2px);
      box-shadow: none;
      text-decoration: none;
    }

    .result-meta {
      display: flex;
      gap: 10px;
      color: var(--muted);
      font-size: 0.82rem;
      flex-wrap: wrap;
      font-weight: 500;
    }

    .result-meta strong {
      color: var(--brand);
    }

    .result-title {
      margin: 0;
      color: var(--text);
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .result-desc {
      margin: 0;
      color: var(--muted);
      font-weight: 500;
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const rawIndex = document.getElementById("search-index")?.textContent ?? "[]";
      const index = JSON.parse(rawIndex);
      const input = document.querySelector("[data-search-input]");
      const results = document.querySelector("[data-search-results]");
      const summary = document.querySelector("[data-search-summary]");
      const chips = [...document.querySelectorAll("[data-category]")];
      const params = new URLSearchParams(window.location.search);
      let activeCategory = params.get("category") || "all";

      const normalize = (value) =>
        value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/đ/g, "d");

      const render = () => {
        const query = normalize(input.value.trim());
        const filtered = index.filter((item) => {
          const matchesCategory = activeCategory === "all" || item.category === activeCategory;
          const haystack = normalize(item.text);
          const matchesQuery = !query || query.split(/\s+/).every((part) => haystack.includes(part));
          return matchesCategory && matchesQuery;
        });

        summary.textContent = `${filtered.length} bài viết phù hợp`;
        results.innerHTML = filtered.length
          ? filtered.map((item) => `
              <a class="result-card" href="${item.href}">
                <span class="result-meta">
                  <strong>${item.categoryLabel}</strong>
                  <span>${item.readingTime}</span>
                  <span>Cập nhật ${item.updatedDate}</span>
                </span>
                <h2 class="result-title">${item.title}</h2>
                <p class="result-desc">${item.description}</p>
              </a>
            `).join("")
          : `<div class="result-card"><h2 class="result-title">Không tìm thấy bài phù hợp</h2><p class="result-desc">Hãy thử từ khóa rộng hơn hoặc chọn tất cả chủ đề.</p></div>`;
      };

      const updateURL = () => {
        const query = input.value.trim();
        const newParams = new URLSearchParams();
        if (query) newParams.set("q", query);
        if (activeCategory && activeCategory !== "all") newParams.set("category", activeCategory);
        const newUrl = `${window.location.pathname}${newParams.toString() ? '?' + newParams.toString() : ''}`;
        window.history.replaceState(null, "", newUrl);
      };

      if (input) {
        input.value = params.get("q") || "";
        input.addEventListener("input", () => {
          render();
          updateURL();
        });
      }

      chips.forEach((chip) => {
        chip.classList.toggle("is-active", chip.dataset.category === activeCategory);
        chip.addEventListener("click", () => {
          activeCategory = chip.dataset.category;
          chips.forEach((item) => item.classList.toggle("is-active", item === chip));
          render();
          updateURL();
        });
      });

      // Prevent form submission from reloading the page
      const form = document.querySelector("[data-search-form]");
      if (form) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          render();
          updateURL();
        });
      }

      render();
    });
  </script>
</BaseLayout>
