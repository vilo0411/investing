---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleList from "@/components/ArticleList.astro";
import { categories, categoryMeta, getCategoryPath, getArticlePath, site } from "@/data/site";
import { author } from "@/data/authors";

const articles = await getCollection("articles");

// Featured article
const featured = articles.find((a) => a.data.featured)
  ?? articles.toSorted((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime())[0];

// Latest 4 excluding featured — for the "Mới nhất" column
const latest = articles
  .filter((a) => a.id !== featured?.id)
  .toSorted((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime())
  .slice(0, 4);

// Per-category: first 3 articles in reading order
const byCategory = categories
  .map((cat) => ({
    ...cat,
    articles: articles
      .filter((a) => a.data.category === cat.slug)
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 3),
  }))
  .filter((cat) => cat.articles.length > 0);

const topicGroups = [
  { title: "Đầu tư", href: "/dau-tu/", description: "Cổ phiếu, ETF, quỹ đầu tư, trái phiếu và các loại tài sản phổ biến." },
  { title: "Phân tích", href: "/phan-tich/", description: "P/E, P/B, ROE, EPS và cách đọc chỉ số tài chính trong bối cảnh doanh nghiệp." },
  { title: "Reviews", href: "/reviews/", description: "Tiêu chí đánh giá công ty chứng khoán và sản phẩm đầu tư cho người mới." },
  { title: "Nhà đầu tư", href: "/nha-dau-tu/", description: "Bài học từ các nhà đầu tư dài hạn và triết lý đầu tư giá trị." },
];

const startSlugs = ["co-phieu-la-gi", "etf-la-gi", "quy-mo-la-gi", "pe-la-gi"];
const startHere = startSlugs
  .map((slug) => articles.find((article) => article.slug === slug))
  .filter((article): article is NonNullable<typeof article> => Boolean(article));
---

<BaseLayout title={site.name} description={site.description}>
  <section class="home-hero">
    <div class="container home-hero-grid">
      <div>
        <div class="eyebrow">Giáo dục đầu tư cho người Việt</div>
        <h1>Đầu tư dễ hiểu hơn.</h1>
        <p class="lead">
          Kiến thức đầu tư, phân tích tài chính và đánh giá sản phẩm đầu tư dành cho người mới bắt đầu.
        </p>
        <div class="hero-actions">
          <a class="primary-action" href="/dau-tu/">Khám phá chủ đề</a>
          <a class="secondary-action" href="/search/">Tìm bài viết</a>
        </div>
      </div>
      <aside class="hero-trust-panel" aria-label="Nguyên tắc nội dung">
        <p class="panel-label">Trust first</p>
        {site.trustStats.map((item) => <span>{item}</span>)}
      </aside>
    </div>
  </section>

  <section class="section topic-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Khám phá theo chủ đề</div>
          <h2 class="section-title">Thư viện kiến thức đầu tư</h2>
        </div>
      </div>
      <div class="topic-grid">
        {topicGroups.map((topic) => (
          <a class="topic-card" href={topic.href}>
            <h3>{topic.title}</h3>
            <p>{topic.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section start-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Bắt đầu từ đâu</div>
          <h2 class="section-title">Lộ trình nền tảng cho người mới</h2>
        </div>
      </div>
      <div class="start-list">
        {startHere.map((article, index) => {
          const meta = categoryMeta[article.data.category] ?? { label: article.data.category, gradientClass: "thumb-stocks", abbr: "?" };
          return (
            <a class="start-item" href={getArticlePath(article)}>
              <span class="start-number">{String(index + 1).padStart(2, "0")}</span>
              <span>
                <strong>{article.data.title}</strong>
                <small>{meta.label} · {article.data.readingTime}</small>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── Top story + latest ──────────────────────────────────────────────── -->
  <section class="top-section">
    <div class="container top-grid">

      <!-- Featured article -->
      {featured && (() => {
        const meta = categoryMeta[featured.data.category] ?? { gradientClass: "thumb-stocks", label: featured.data.category };
        return (
          <a class="featured-card" href={getArticlePath(featured)}>
            <div class={`featured-thumb ${meta.gradientClass}`}>
              <span class="featured-thumb-label">{meta.label}</span>
            </div>
            <div class="featured-body">
              <div class="featured-meta">
                <span class="article-tag">{meta.label}</span>
                <span class="article-date">
                  {featured.data.updatedDate.toLocaleDateString("vi-VN", { day: "numeric", month: "long", year: "numeric" })}
                </span>
              </div>
              <h1 class="featured-title">{featured.data.title}</h1>
              <p class="featured-desc">{featured.data.description}</p>
              <span class="featured-cta">Đọc bài viết <span aria-hidden="true">→</span></span>
            </div>
          </a>
        );
      })()}

      <!-- Latest articles column -->
      <aside class="latest-col">
        <h2 class="col-heading">Mới nhất</h2>
        <ul class="latest-list">
          {latest.map((article) => {
            const meta = categoryMeta[article.data.category] ?? { gradientClass: "thumb-stocks", label: article.data.category };
            return (
              <li class="latest-item">
                <a class="latest-link" href={getArticlePath(article)}>
                  <div class={`latest-thumb ${meta.gradientClass}`}></div>
                  <div class="latest-text">
                    <span class="article-tag latest-tag">{meta.label}</span>
                    <span class="latest-title">{article.data.title}</span>
                    <span class="latest-time">{article.data.readingTime}</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </aside>

    </div>
  </section>

  <section class="trust-band" aria-label="Nguyên tắc tin cậy">
    <div class="container trust-grid">
      <div>
        <div class="eyebrow">EEAT & YMYL</div>
        <h2 class="trust-title">Thông tin đầu tư cần minh bạch trước khi hữu ích.</h2>
      </div>
      <div class="trust-items">
        {site.trustStats.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section author-home">
    <div class="container author-home-grid">
      <div>
        <div class="eyebrow">Tác giả</div>
        <h2 class="section-title">{author.name}</h2>
        <p>
          Phụ trách nội dung theo hướng giáo dục, có nguồn, không khuyến nghị mua bán và ưu tiên khả năng tự học của nhà đầu tư cá nhân.
        </p>
      </div>
      <a class="see-all" href="/about/">Xem hồ sơ tác giả <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- ── Category sections ───────────────────────────────────────────────── -->
  {byCategory.map((cat) => (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <div class="eyebrow">{cat.group}</div>
            <h2 class="section-title">{cat.title}</h2>
          </div>
          <a class="see-all" href={getCategoryPath(cat)}>
            Xem tất cả <span aria-hidden="true">→</span>
          </a>
        </div>
        <ArticleList articles={cat.articles} />
      </div>
    </section>
  ))}

</BaseLayout>

<style>
  .home-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    padding: 58px 0 46px;
  }

  .home-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 48px;
    align-items: end;
  }

  .home-hero h1 {
    color: var(--text);
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  .primary-action,
  .secondary-action {
    border-radius: var(--radius-md);
    font-weight: 800;
    line-height: 1.2;
    padding: 12px 16px;
    text-decoration: none;
  }

  .primary-action {
    background: var(--color-brand-900);
    color: #fff;
  }

  .primary-action:hover {
    background: var(--color-brand-700);
    color: #fff;
    text-decoration: none;
  }

  .secondary-action {
    border: 1px solid var(--line);
    color: var(--brand);
    background: var(--surface);
  }

  .secondary-action:hover {
    border-color: var(--color-brand-100);
    background: var(--color-brand-100);
    text-decoration: none;
  }

  .hero-trust-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 22px;
    display: grid;
    gap: 10px;
  }

  .panel-label {
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .hero-trust-panel span {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    padding-top: 10px;
  }

  .topic-grid,
  .start-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .topic-card,
  .start-item {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 20px;
    text-decoration: none;
  }

  .topic-card:hover,
  .start-item:hover {
    border-color: var(--color-brand-100);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .topic-card h3 {
    color: var(--text);
  }

  .topic-card p {
    color: var(--muted);
    margin: 0;
    font-size: 0.92rem;
  }

  .start-section {
    background: var(--color-neutral-100);
  }

  .start-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: start;
  }

  .start-number {
    color: var(--color-accent);
    font-weight: 800;
  }

  .start-item strong {
    color: var(--text);
    display: block;
    line-height: 1.35;
  }

  .start-item small {
    color: var(--muted);
    display: block;
    margin-top: 6px;
  }

  /* ── Top section ─────────────────────────────────────────────────────── */
  .top-section {
    border-bottom: 1px solid var(--line);
    padding: 40px 0 48px;
    background: var(--surface);
  }

  .top-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    align-items: start;
  }

  /* ── Featured card ───────────────────────────────────────────────────── */
  .featured-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    overflow: hidden;
    background: var(--surface);
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .featured-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-brand-100);
    text-decoration: none;
  }

  .featured-thumb {
    width: 100%;
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: flex-end;
    padding: 20px 24px;
  }

  .featured-thumb-label {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.18);
    letter-spacing: 0.02em;
  }

  .featured-body {
    padding: 24px 28px 28px;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .featured-card:hover .featured-title {
    color: var(--brand);
  }

  .featured-desc {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0 0 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-brand-900);
  }

  /* ── Latest column ───────────────────────────────────────────────────── */
  .latest-col {
    display: flex;
    flex-direction: column;
  }

  .col-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--brand);
    font-family: var(--font-sans);
  }

  .latest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .latest-item {
    border-bottom: 1px solid var(--line);
  }

  .latest-item:last-child {
    border-bottom: none;
  }

  .latest-link {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 0;
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .latest-link:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  .latest-thumb {
    width: 64px;
    height: 52px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .latest-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .latest-tag {
    font-size: 10px !important;
    padding: 2px 8px !important;
  }

  .latest-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .latest-link:hover .latest-title {
    color: var(--brand);
  }

  .latest-time {
    font-size: 0.78rem;
    color: var(--muted);
  }

  /* ── Shared article tag / date ───────────────────────────────────────── */
  .article-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-brand-900);
    white-space: nowrap;
  }

  .article-date {
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* ── Trust band ──────────────────────────────────────────────────────── */
  .trust-band {
    border-bottom: 1px solid var(--line);
    background: var(--color-neutral-100);
    padding: 30px 0;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 28px;
    align-items: start;
  }

  .trust-title {
    margin: 6px 0 0;
    color: var(--text);
    font-size: clamp(1.35rem, 2vw, 1.8rem);
  }

  .trust-items {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .trust-items p {
    margin: 0;
    min-height: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    padding: 14px 16px;
  }

  /* ── Category sections ───────────────────────────────────────────────── */
  .section {
    padding: 44px 0;
    border-bottom: 1px solid var(--line);
  }

  .section:last-child {
    border-bottom: none;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 24px;
  }

  .section-title {
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    margin: 4px 0 0;
    color: var(--text);
  }

  .see-all {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-brand-700);
    white-space: nowrap;
    text-decoration: none;
    flex-shrink: 0;
  }

  .see-all:hover {
    color: var(--color-brand-900);
    text-decoration: none;
  }

  /* Gradient thumbnails (shared with ArticleList) */
  .thumb-stocks   { background: linear-gradient(135deg, #e8f8ee, #a7f3c0); }
  .thumb-etf      { background: linear-gradient(135deg, #eef2ff, #c7d2fe); }
  .thumb-fund     { background: linear-gradient(135deg, #fdf4ff, #e9d5ff); }
  .thumb-bond     { background: linear-gradient(135deg, #eff6ff, #bfdbfe); }
  .thumb-derivative { background: linear-gradient(135deg, #ecfeff, #a5f3fc); }
  .thumb-analyse  { background: linear-gradient(135deg, #fff7ed, #fed7aa); }
  .thumb-technical { background: linear-gradient(135deg, #f0fdf4, #bbf7d0); }
  .thumb-review   { background: linear-gradient(135deg, #fdf2f8, #fbcfe8); }
  .thumb-investor { background: linear-gradient(135deg, #fefce8, #fde68a); }

  .author-home {
    background: var(--surface);
  }

  .author-home-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
  }

  .author-home p {
    color: var(--muted);
    margin: 0;
    max-width: 720px;
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .home-hero-grid,
    .top-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .trust-grid,
    .trust-items {
      grid-template-columns: 1fr;
    }

    .latest-col {
      border-top: 1px solid var(--line);
      padding-top: 28px;
    }

    .col-heading {
      margin-top: 0;
    }
  }

  @media (max-width: 640px) {
    .topic-grid,
    .start-list,
    .author-home-grid {
      grid-template-columns: 1fr;
    }

    .top-section { padding: 28px 0 36px; }
    .featured-body { padding: 18px 20px 22px; }
    .section { padding: 32px 0; }
  }
</style>
