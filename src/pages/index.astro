---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleList from "@/components/ArticleList.astro";
import StartHereGrid from "@/components/StartHereGrid.astro";
import EeatBanner from "@/components/EeatBanner.astro";
import { categories, getCategoryPath, site, url } from "@/data/site";

const articles = await getCollection("articles");

// Per-category: first 3 latest articles (sorted by updatedDate descending)
const byCategory = categories
  .map((cat) => ({
    ...cat,
    articles: articles
      .filter((a) => a.data.category === cat.slug)
      .sort((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime())
      .slice(0, 3),
  }))
  .filter((cat) => cat.articles.length > 0);

const startSlugs = [
  "cach-dau-tu-co-phieu",
  "cach-dau-tu-trai-phieu",
  "cach-dau-tu-quy-etf",
  "cach-dau-tu-chung-khoan-phai-sinh",
];
const startHere = startSlugs
  .map((slug) => articles.find((article) => article.slug === slug))
  .filter((article): article is NonNullable<typeof article> => Boolean(article));
---

<BaseLayout title={site.name} description={site.description}>
  <section class="home-hero">
    <div class="container home-hero-grid">
      <div>
        <div class="eyebrow">Giáo dục đầu tư cho người Việt</div>
        <h1>Đầu tư dễ hiểu hơn.</h1>
        <p class="lead">
          Kiến thức đầu tư, phân tích tài chính và đánh giá sản phẩm đầu tư dành cho người mới bắt đầu.
        </p>
        <div class="hero-actions">
          <a class="primary-action" href={url("/dau-tu/")}>Khám phá chủ đề</a>
          <a class="secondary-action" href={url("/search/")}>Tìm bài viết</a>
        </div>
      </div>
      <aside class="hero-trust-panel" aria-label="Nguyên tắc nội dung">
        <p class="panel-label">Trust first</p>
        {site.trustStats.map((item) => <span>{item}</span>)}
      </aside>
    </div>
  </section>

  <!-- Onboarding for new users, placed prominently right below hero -->
  <section class="section start-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Bắt đầu từ đâu</div>
          <h2 class="section-title">Lộ trình nền tảng cho người mới</h2>
        </div>
      </div>
      <StartHereGrid articles={startHere} />
    </div>
  </section>

  <!-- Interactive Category Tabs to showcase all content in a single clean viewport -->
  <section class="section category-tabs-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Khám phá theo chuyên mục</div>
          <h2 class="section-title">Bài viết nổi bật</h2>
        </div>
      </div>

      <div class="tab-buttons-container">
        {byCategory.map((cat, index) => (
          <button
            class={`tab-button ${index === 0 ? "active" : ""}`}
            data-category={cat.slug}
          >
            {cat.title}
          </button>
        ))}
      </div>

      <div class="tab-contents-container">
        {byCategory.map((cat, index) => (
          <div
            class={`tab-content-panel ${index === 0 ? "active" : ""}`}
            data-category-panel={cat.slug}
          >
            <ArticleList articles={cat.articles} />
            <div class="tab-panel-footer">
              <a class="primary-action see-all-button" href={getCategoryPath(cat)}>
                Xem tất cả bài viết {cat.title} <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cohesive E-E-A-T block merging Author Profile and Editorial Transparency -->
  <EeatBanner />

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll(".tab-button");
    const panels = document.querySelectorAll(".tab-content-panel");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-category");

        buttons.forEach((b) => b.classList.remove("active"));
        panels.forEach((p) => p.classList.remove("active"));

        btn.classList.add("active");
        const activePanel = document.querySelector(`[data-category-panel="${target}"]`);
        if (activePanel) {
          activePanel.classList.add("active");
        }
      });
    });
  });
</script>

<style>
  .home-hero {
    background: var(--surface);
    border-bottom: 2px solid var(--line);
    padding: 96px 0;
  }

  .home-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 48px;
    align-items: end;
  }

  .home-hero h1 {
    color: var(--text);
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.88rem;
    letter-spacing: 0.05em;
    padding: 12px 24px;
    border: 1px solid var(--line);
    border-radius: 0px;
    cursor: pointer;
    text-decoration: none;
    line-height: 1.2;
  }

  .primary-action {
    background: var(--brand);
    color: #fff !important;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .primary-action:hover {
    transform: translate(4px, 4px);
    box-shadow: none;
    color: #fff;
    text-decoration: none;
  }

  .secondary-action {
    color: var(--text) !important;
    background: transparent;
    box-shadow: none;
    transition: background var(--transition-fast);
  }

  .secondary-action:hover {
    background: var(--surface-alt);
    text-decoration: none;
  }

  .hero-trust-panel {
    border: 1px solid var(--line);
    border-radius: 0px;
    background: var(--surface);
    padding: 22px;
    display: grid;
    gap: 10px;
    box-shadow: var(--shadow-sm);
  }

  .panel-label {
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .hero-trust-panel span {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    padding-top: 10px;
  }

  .start-section {
    background: var(--surface-alt);
  }

  /* ── Category sections ───────────────────────────────────────────────── */
  .section {
    padding: 80px 0;
    border-bottom: 2px solid var(--line);
  }

  .section:last-child {
    border-bottom: none;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 32px;
  }

  .section-title {
    font-size: clamp(1.25rem, 2.2vw, 1.8rem);
    margin: 4px 0 0;
    color: var(--text);
    font-weight: 700;
  }

  /* ── Tab Filter system ────────────────────────────────────────────────── */
  .category-tabs-section {
    background: var(--surface);
    border-bottom: 2px solid var(--line);
  }

  .tab-buttons-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-bottom: 8px;
  }

  .tab-button {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 10px 18px;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: 0px;
    cursor: pointer;
    box-shadow: 2px 2px 0px var(--line);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }

  .tab-button:hover {
    background: var(--surface-alt);
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px var(--line);
  }

  .tab-button.active {
    background: var(--color-mint);
    border: 2px solid var(--line);
    box-shadow: none;
    transform: translate(2px, 2px);
  }

  .tab-content-panel {
    display: none;
  }

  .tab-content-panel.active {
    display: block;
    animation: tabFadeIn 0.25s ease-out;
  }

  @keyframes tabFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tab-panel-footer {
    display: flex;
    justify-content: center;
    margin-top: 36px;
  }

  .see-all-button {
    text-decoration: none;
    background: var(--surface-alt) !important;
    color: var(--text) !important;
    font-size: 0.85rem;
    font-weight: 700;
    box-shadow: 3px 3px 0px var(--line);
  }
  
  .see-all-button:hover {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0px var(--line);
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .home-hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 640px) {
    .section { padding: 48px 0; }
  }
</style>
</BaseLayout>
