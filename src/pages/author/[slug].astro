---
import { getCollection } from "astro:content";
import ArticleList from "@/components/ArticleList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { author } from "@/data/authors";

export async function getStaticPaths() {
  return [{ params: { slug: author.slug }, props: { author } }];
}

const { author: profileAuthor } = Astro.props;

const articles = (await getCollection("articles")).toSorted(
  (a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime(),
);

const authorInitial = profileAuthor.name.split(" ").pop()?.charAt(0) ?? profileAuthor.name.charAt(0);
const pageSize = 6;
---

<BaseLayout title={profileAuthor.name} description={profileAuthor.bio}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${Astro.site}author/${profileAuthor.slug}/#person`,
    "name": profileAuthor.name,
    "url": `${Astro.site}author/${profileAuthor.slug}/`,
    "jobTitle": profileAuthor.role,
    "description": profileAuthor.bio,
    "knowsAbout": profileAuthor.expertise,
    "sameAs": profileAuthor.socialLinks
      ? [
          profileAuthor.socialLinks.linkedin,
          profileAuthor.socialLinks.twitter
        ].filter(Boolean)
      : []
  })} />
  <section class="author-hero">
    <div class="container author-hero-grid">
      <div class="author-identity">
        <div class="author-avatar-large" aria-hidden="true">
          {profileAuthor.avatar
            ? <img src={profileAuthor.avatar} alt={profileAuthor.name} width="200" height="200" />
            : authorInitial
          }
        </div>
        <div class="author-meta">
          <p class="author-label-top">Tác giả</p>
          <h1>{profileAuthor.name}</h1>
          <p class="author-role">{profileAuthor.role}</p>
          <div class="author-expertise-inline">
            {profileAuthor.expertise.map((item) => <span>{item}</span>)}
          </div>
          {profileAuthor.socialLinks?.linkedin && (
            <a class="author-linkedin" href={profileAuthor.socialLinks.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn →</a>
          )}
        </div>
      </div>

      <aside class="expertise-panel" aria-label="Chuyên môn tác giả">
        <p class="panel-label">Kinh nghiệm nội dung</p>
        <p class="panel-body">{profileAuthor.experience}</p>
      </aside>
    </div>
  </section>

  <section class="author-body">
    <div class="container author-layout">
      <main class="author-main">
        <section class="quote-block" aria-label="Quan điểm về tiền và đầu tư">
          <p class="panel-label">Quan điểm về đầu tư</p>
          <blockquote>“{profileAuthor.moneyPerspective}”</blockquote>
        </section>

        <section class="bio-section">
          <h2>Tiểu sử</h2>
          <p>{profileAuthor.bio}</p>

          {profileAuthor.credentials.length > 0 && (
            <>
              <h3>Chứng chỉ</h3>
              <ul>
                {profileAuthor.credentials.map((credential) => <li>{credential}</li>)}
              </ul>
            </>
          )}
        </section>

        <section class="latest-section">
          <p class="panel-label">Bài viết mới</p>
          <h2>Tất cả bài viết</h2>
          <ArticleList articles={articles} />

          {articles.length > pageSize && (
            <div class="pagination-container">
              <button class="btn-load-more" id="btn-load-more">
                Tải thêm bài viết
              </button>
            </div>
          )}

          <noscript>
            <style>
              .card-grid .article-card:nth-child(n+7) {
                display: flex !important;
              }
              .btn-load-more {
                display: none !important;
              }
            </style>
          </noscript>
        </section>
      </main>

      <aside class="author-sidebar" aria-label="Thông tin hồ sơ">
        <div class="profile-card">
          <h2>Kinh nghiệm nội dung</h2>
          <p>{profileAuthor.experience}</p>
        </div>

        <div class="profile-card">
          <h2>Học văn</h2>
          <p>{profileAuthor.education}</p>
        </div>

        {profileAuthor.socialLinks && (
          <div class="profile-card profile-links">
            <h2>Liên hệ</h2>
            <div class="profile-links-row">
              {profileAuthor.socialLinks.linkedin && (
                <a href={profileAuthor.socialLinks.linkedin}>LinkedIn</a>
              )}
              {profileAuthor.socialLinks.twitter && (
                <a href={profileAuthor.socialLinks.twitter}>Twitter</a>
              )}
              {profileAuthor.socialLinks.email && (
                <a href={`mailto:${profileAuthor.socialLinks.email}`}>Email</a>
              )}
            </div>
          </div>
        )}

        <div class="profile-card">
          <h2>Xuất hiện trên</h2>
          <div class="published-list">
            {profileAuthor.publishedIn.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  // Handle Load More DOM-based for author page
  const loadMoreBtn = document.getElementById("btn-load-more");
  const cards = Array.from(document.querySelectorAll(".card-grid .article-card"));
  const pageSize = 6;
  let visibleCount = pageSize;

  if (loadMoreBtn && cards.length > pageSize) {
    loadMoreBtn.addEventListener("click", () => {
      // Reveal the next pageSize cards
      const nextBatch = cards.slice(visibleCount, visibleCount + pageSize);
      nextBatch.forEach((card) => {
        card.classList.add("is-revealed");
      });
      visibleCount += pageSize;

      // If no more hidden cards, remove the button
      if (visibleCount >= cards.length) {
        loadMoreBtn.remove();
      }
    });
  }
</script>

<style>
  /* Hide cards starting from the 7th card on load */
  .card-grid :global(.article-card:nth-child(n+7)) {
    display: none !important;
  }

  /* Override hidden cards when they are revealed via JS */
  .card-grid :global(.article-card.is-revealed) {
    display: flex !important;
  }

  .author-hero {
    background: var(--surface);
    border-bottom: 2px solid var(--line);
    padding: 52px 0 44px;
  }

  .author-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 48px;
    align-items: center;
  }

  .author-identity {
    display: flex;
    gap: 36px;
    align-items: center;
  }

  .author-avatar-large {
    flex-shrink: 0;
    width: 200px;
    height: 200px;
    border-radius: 0;
    border: 2px solid var(--line);
    background: var(--brand);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 5.5rem;
    line-height: 1;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .author-avatar-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .author-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .author-label-top {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand);
  }

  .author-identity h1 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .author-role {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .author-expertise-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .author-expertise-inline span {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--color-mint);
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 9px;
  }

  .author-linkedin {
    display: inline-block;
    margin-top: 4px;
    color: var(--brand);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
  }

  .author-linkedin:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .expertise-panel,
  .quote-block,
  .profile-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .expertise-panel {
    padding: 24px 26px;
    border-left: 4px solid var(--brand);
  }

  .panel-label {
    margin: 0 0 10px;
    color: var(--brand);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .panel-body {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
    font-weight: 500;
  }

  .expertise-panel ul,
  .profile-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--text);
    line-height: 1.7;
    font-weight: 500;
  }

  .author-body {
    padding: 42px 0 64px;
  }

  .author-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: start;
  }

  .author-main {
    display: grid;
    gap: 34px;
  }

  .quote-block {
    padding: 26px 28px;
    border-left: 8px solid var(--brand);
    background: var(--color-mint);
  }

  .quote-block blockquote {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.05rem);
    line-height: 1.25;
    font-weight: 700;
  }

  .bio-section h2,
  .bio-section h3,
  .latest-section h2,
  .profile-card h2 {
    margin: 0 0 12px;
    color: var(--text);
    font-weight: 700;
  }

  .bio-section h2,
  .latest-section h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.05rem);
  }

  .bio-section h3 {
    font-size: 1.1rem;
  }

  .bio-section p,
  .profile-card p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 14px;
    font-weight: 500;
  }

  .latest-section .panel-label {
    margin-bottom: 8px;
  }

  .latest-section h2 {
    margin-bottom: 18px;
  }

  .author-sidebar {
    display: grid;
    gap: 18px;
    position: sticky;
    top: 96px;
  }

  .profile-card {
    padding: 22px;
  }

  .profile-card h2 {
    font-size: 1.15rem;
  }

  .profile-card p,
  .profile-card li {
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.65;
    font-weight: 500;
  }

  .profile-links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .profile-links-row a {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .profile-links-row a:hover {
    color: var(--brand-strong);
  }

  .published-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .published-list span {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--color-mint);
    color: var(--text);
    font-size: 0.84rem;
    font-weight: 700;
    padding: 6px 10px;
    box-shadow: 1px 1px 0px var(--line);
  }

  @media (max-width: 900px) {
    .author-hero-grid,
    .author-layout {
      grid-template-columns: 1fr;
    }

    .author-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .author-hero {
      padding: 32px 0 28px;
    }

    .author-identity {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .author-avatar-large {
      width: 120px;
      height: 120px;
      font-size: 3.2rem;
    }
  }
</style>
