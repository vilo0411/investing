---
import { getCollection } from "astro:content";
import ArticleList from "@/components/ArticleList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { author } from "@/data/authors";

// Single author today; written array-friendly so a future `authors: Author[]`
// export in authors.ts can be mapped over without restructuring this page (D-06).
export async function getStaticPaths() {
  return [{ params: { slug: author.slug }, props: { author } }];
}

const { author: profileAuthor } = Astro.props;

const articles = (await getCollection("articles")).toSorted(
  (a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime(),
);

const authorInitial = profileAuthor.name.split(" ").pop()?.charAt(0) ?? profileAuthor.name.charAt(0);
---

<BaseLayout title={profileAuthor.name} description={profileAuthor.bio}>
  <section class="author-hero">
    <div class="container author-hero-grid">
      <div class="author-identity">
        <div class="author-avatar-large" aria-hidden="true">{authorInitial}</div>
        <div>
          <h1>{profileAuthor.name}</h1>
          <p class="author-role">{profileAuthor.role}</p>
        </div>
      </div>

      <aside class="expertise-panel" aria-label="Chuyên môn tác giả">
        <p class="panel-label">Chuyên môn</p>
        <ul>
          {profileAuthor.expertise.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="author-body">
    <div class="container author-layout">
      <main class="author-main">
        <section class="quote-block" aria-label="Quan điểm về tiền và đầu tư">
          <p class="panel-label">Quan điểm về đầu tư</p>
          <blockquote>“{profileAuthor.moneyPerspective}”</blockquote>
        </section>

        <section class="bio-section">
          <h2>Tiểu sử</h2>
          <p>{profileAuthor.bio}</p>

          {profileAuthor.credentials.length > 0 && (
            <>
              <h3>Chứng chỉ</h3>
              <ul>
                {profileAuthor.credentials.map((credential) => <li>{credential}</li>)}
              </ul>
            </>
          )}
        </section>

        <section class="latest-section">
          <p class="panel-label">Bài viết mới</p>
          <h2>Tất cả bài viết</h2>
          <ArticleList articles={articles} />
        </section>
      </main>

      <aside class="author-sidebar" aria-label="Thông tin hồ sơ">
        <div class="profile-card">
          <h2>Kinh nghiệm nội dung</h2>
          <p>{profileAuthor.experience}</p>
        </div>

        <div class="profile-card">
          <h2>Học vấn</h2>
          <p>{profileAuthor.education}</p>
        </div>

        {profileAuthor.socialLinks && (
          <div class="profile-card profile-links">
            <h2>Liên hệ</h2>
            <div class="profile-links-row">
              {profileAuthor.socialLinks.linkedin && (
                <a href={profileAuthor.socialLinks.linkedin}>LinkedIn</a>
              )}
              {profileAuthor.socialLinks.twitter && (
                <a href={profileAuthor.socialLinks.twitter}>Twitter</a>
              )}
              {profileAuthor.socialLinks.email && (
                <a href={`mailto:${profileAuthor.socialLinks.email}`}>Email</a>
              )}
            </div>
          </div>
        )}

        <div class="profile-card">
          <h2>Xuất hiện trên</h2>
          <div class="published-list">
            {profileAuthor.publishedIn.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .author-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    padding: 52px 0 34px;
  }

  .author-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: end;
  }

  .author-identity {
    display: grid;
    grid-template-columns: 148px minmax(0, 1fr);
    gap: 28px;
    align-items: center;
  }

  .author-avatar-large {
    width: 148px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 26%, var(--color-neutral-50) 0 0, var(--color-neutral-50) 18%, var(--color-brand-700) 19%, var(--color-brand-900) 72%);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 4.4rem;
    line-height: 1;
    box-shadow: 0 10px 28px rgba(10, 37, 64, 0.18);
  }

  .author-identity h1 {
    margin: 0 0 8px;
    color: var(--text);
    font-size: clamp(2.4rem, 5vw, 4.3rem);
  }

  .author-role {
    margin: 0;
    color: var(--muted);
    font-size: 1.05rem;
    font-weight: 700;
  }

  .expertise-panel,
  .quote-block,
  .profile-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .expertise-panel {
    padding: 22px;
  }

  .panel-label {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .expertise-panel ul,
  .profile-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    line-height: 1.7;
  }

  .author-body {
    padding: 42px 0 64px;
  }

  .author-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: start;
  }

  .author-main {
    display: grid;
    gap: 34px;
  }

  .quote-block {
    padding: 26px 28px;
    border-left: 4px solid var(--color-brand-900);
  }

  .quote-block blockquote {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.05rem);
    line-height: 1.25;
  }

  .bio-section h2,
  .bio-section h3,
  .latest-section h2,
  .profile-card h2 {
    margin: 0 0 12px;
    color: var(--text);
  }

  .bio-section h2,
  .latest-section h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.05rem);
  }

  .bio-section h3 {
    font-size: 1.1rem;
  }

  .bio-section p,
  .profile-card p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 14px;
  }

  .latest-section .panel-label {
    margin-bottom: 8px;
  }

  .latest-section h2 {
    margin-bottom: 18px;
  }

  .author-sidebar {
    display: grid;
    gap: 18px;
    position: sticky;
    top: 96px;
  }

  .profile-card {
    padding: 22px;
  }

  .profile-card h2 {
    font-size: 1.15rem;
  }

  .profile-card p,
  .profile-card li {
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .profile-links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .profile-links-row a {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .profile-links-row a:hover {
    text-decoration: underline;
  }

  .published-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .published-list span {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--brand);
    font-size: 0.84rem;
    font-weight: 700;
    padding: 6px 10px;
  }

  @media (max-width: 900px) {
    .author-hero-grid,
    .author-layout {
      grid-template-columns: 1fr;
    }

    .author-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .author-hero {
      padding-top: 34px;
    }

    .author-identity {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .author-avatar-large {
      width: 112px;
      font-size: 3.2rem;
    }
  }
</style>
