---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, url } from "@/data/site";
import { author } from "@/data/authors";

const contactReasons = [
  {
    label: "Đính chính thông tin",
    description:
      "Phát hiện số liệu sai, khái niệm không chính xác hoặc nội dung đã lỗi thời — Value Investing rất muốn được biết để sửa kịp thời.",
    link: url("/corrections-policy/"),
    linkText: "Xem chính sách đính chính",
  },
  {
    label: "Đề xuất chủ đề",
    description:
      "Có chủ đề đầu tư, sản phẩm tài chính hoặc câu hỏi thực tế mà bạn muốn tìm hiểu nhưng chưa thấy trên blog.",
    link: null,
    linkText: null,
  },
  {
    label: "Góp ý nội dung",
    description:
      "Bài viết còn khó hiểu, thiếu ví dụ thực tế, hoặc bạn có góc nhìn bổ sung muốn chia sẻ.",
    link: null,
    linkText: null,
  },
  {
    label: "Hợp tác nội dung",
    description:
      "Bạn có kinh nghiệm đầu tư thực chiến và muốn cộng tác, chia sẻ góc nhìn cá nhân cho bài viết.",
    link: null,
    linkText: null,
  },
];
---

<BaseLayout
  title="Liên hệ với Value Investing"
  description="Liên hệ để góp ý nội dung, báo lỗi thông tin hoặc đề xuất chủ đề đầu tư mới. Phản hồi trong 24–48 giờ làm việc."
>
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Liên hệ</div>
      <h1>Gửi phản hồi cho Value Investing</h1>
      <p class="lead">
        Value Investing đọc mọi tin nhắn và phản hồi trong vòng 24–48 giờ làm việc. Blog không nhận câu hỏi
        tư vấn đầu tư cá nhân — xem <a href={url("/disclaimer/")}>disclaimer</a> để hiểu rõ hơn.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Bạn muốn liên hệ về điều gì?</div>
          <h2 class="section-title">Lý do liên hệ</h2>
        </div>
      </div>
      <div class="reasons-grid">
        {
          contactReasons.map((reason) => (
            <div class="reason-card">
              <div class="reason-label">{reason.label}</div>
              <p>{reason.description}</p>
              {reason.link && (
                <a class="reason-link" href={reason.link}>
                  {reason.linkText}
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Thông tin liên hệ</div>
          <h2 class="section-title">Cách liên hệ</h2>
        </div>
      </div>
      <div class="contact-card">
        <div class="contact-person">
          <div class="contact-avatar" aria-hidden="true">
            {author.avatar
              ? <img src={url(author.avatar)} alt={author.name} width="80" height="80" />
              : author.name.split(" ").pop()?.charAt(0)
            }
          </div>
          <div>
            <a class="contact-name" href={url(`/author/${author.slug}/`)}>{author.name}</a>
            <span class="contact-role">{author.role}</span>
          </div>
        </div>
        <div class="contact-channels">
          <a class="channel" href={`mailto:${site.email}`}>
            <span class="channel-label">Email</span>
            <span class="channel-value">{site.email}</span>
          </a>
          {
            author.socialLinks.linkedin && (
              <a
                class="channel"
                href={author.socialLinks.linkedin}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="channel-label">LinkedIn</span>
                <span class="channel-value">Nhắn tin trực tiếp</span>
              </a>
            )
          }
        </div>
        <p class="response-note">Phản hồi trong 24–48 giờ làm việc (thứ Hai – thứ Sáu).</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="disclaimer-box">
        <strong>Lưu ý quan trọng</strong>
        <p>{site.disclosure}</p>
        <a href={url("/editorial-policy/")}>Xem chính sách biên tập</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .reason-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 24px;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .reason-card:hover {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .reason-label {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    background: var(--color-mint);
    color: var(--text);
    border: 1px solid var(--line);
    box-shadow: 2px 2px 0px var(--line);
    margin-bottom: 14px;
  }

  .reason-card p {
    margin: 0 0 12px;
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 500;
  }

  .reason-link {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .reason-link:hover {
    color: var(--brand-strong);
  }

  /* Contact card */
  .contact-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    padding: 28px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 560px;
  }

  .contact-person {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
  }

  .contact-avatar {
    width: 80px;
    aspect-ratio: 1;
    background: var(--brand);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    line-height: 1;
    border: 1px solid var(--line);
    box-shadow: 2px 2px 0px var(--line);
  }

  .contact-name {
    display: block;
    color: var(--text);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .contact-name:hover {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .contact-role {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 2px;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .channel {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--bg);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .channel:hover {
    background: var(--surface-alt);
  }

  .channel-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    min-width: 56px;
  }

  .channel-value {
    color: var(--brand);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .response-note {
    margin: 0;
    font-size: 0.88rem;
    color: var(--muted);
    font-weight: 500;
  }

  /* Disclaimer */
  .disclaimer-box {
    border: 1px solid var(--line);
    border-left: 6px solid var(--muted);
    border-radius: 0;
    background: var(--surface-alt);
    padding: 22px 24px;
    box-shadow: var(--shadow-sm);
  }

  .disclaimer-box strong {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .disclaimer-box p {
    margin: 0 0 12px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.65;
    font-weight: 500;
  }

  .disclaimer-box a {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .disclaimer-box a:hover {
    color: var(--brand-strong);
  }

  /* Lead link */
  .lead a {
    color: var(--brand);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .reasons-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
